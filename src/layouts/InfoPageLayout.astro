---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FloatingButton from '../components/FloatingButton.astro';

export interface Props {
	title: string;
    image: { src: string; alt: string };
    icon: string;
    detailedDescription: string[];
}

const { title, image, icon, detailedDescription } = Astro.props;
---

<!DOCTYPE html>
<html lang="ar" dir="ltr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{title} - شركة الإيمان للتطوير العقاري</title>
        <meta name="description" content={detailedDescription[0]}>
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Almarai:wght@400;700&family=Cairo:wght@400;700;900&family=Kalam&display=swap" rel="stylesheet">
    </head>
    <body>
        <Header />
        <main class="info-page">
            <div class="page-header">
                <div class="header-image-container">
                    <img src={image.src} alt={image.alt} class="header-image"/>
                    <div class="header-overlay"></div>
                </div>
                <div class="header-content">
                    <div class="icon-wrapper" set:html={icon}></div>
                    <h1 class="page-title">{title}</h1>
                </div>
            </div>

            <div class="page-content">
                <div class="main-content">
                    <slot />
                </div>
                
                <aside class="sidebar">
                    <div class="detailed-description">
                        <h3>وصف تفصيلي</h3>
                        {detailedDescription.map(p => <p>{p}</p>)}
                    </div>
                    <div class="cta-card">
                        <h4>هل لديك استفسار؟</h4>
                        <p>تواصل معنا الآن للحصول على استشارة مجانية حول مشاريعنا وفرص الاستثمار المتاحة.</p>
                        <a href="/contact" class="cta-button">تواصل معنا</a>
                    </div>
                </aside>
            </div>
        </main>
        <Footer />
        <FloatingButton />
    </body>
</html>

<style>
    body {
        background-color: #f7fafc;
        direction: rtl;
    }

    .info-page {
        max-width: 1200px;
        margin: 0 auto;
        padding: 40px 20px;
    }

    .page-header {
        position: relative;
        margin-bottom: 50px;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }

    .header-image-container {
        width: 100%;
        height: 350px;
    }

    .header-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    .header-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(to top, rgba(0, 0, 0, 0.7) 0%, transparent 60%);
    }

    .header-content {
        position: absolute;
        bottom: 0;
        right: 0;
        padding: 40px;
        color: #fff;
        display: flex;
        align-items: center;
        gap: 20px;
    }

    .icon-wrapper {
        width: 60px;
        height: 60px;
    }
    .icon-wrapper :global(svg) {
        width: 100%;
        height: 100%;
    }

    .page-title {
        font-family: 'Cairo', sans-serif;
        font-size: 3rem;
        font-weight: 900;
        text-shadow: 2px 2px 8px rgba(0,0,0,0.5);
    }

    .page-content {
        display: grid;
        grid-template-columns: 1fr;
        gap: 50px;
    }

    @media (min-width: 992px) {
        .page-content {
            grid-template-columns: 3fr 1fr;
        }
    }

    .main-content :global(h2) {
        font-family: 'Cairo', sans-serif;
        font-size: 2rem;
        color: #2c3e50;
        margin-bottom: 20px;
    }

    .main-content :global(p) {
        font-family: 'Almarai', sans-serif;
        font-size: 1.15rem;
        color: #34495e;
        line-height: 1.9;
        margin-bottom: 20px;
    }

    .sidebar > div {
        background: #fff;
        padding: 25px;
        border-radius: 8px;
        margin-bottom: 30px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
    }

    .sidebar h3, .sidebar h4 {
        font-family: 'Cairo', sans-serif;
        color: #2c3e50;
        margin-bottom: 15px;
    }

    .sidebar p {
        font-family: 'Almarai', sans-serif;
        line-height: 1.8;
        color: #5a6878;
        font-size: 1rem;
    }

    .cta-button {
        display: inline-block;
        margin-top: 20px;
        padding: 12px 25px;
        background-color: #1a5f7a;
        color: #fff;
        text-align: center;
        border-radius: 5px;
        font-weight: 700;
        transition: background-color 0.3s ease;
    }
    .cta-button:hover {
        background-color: #154c63;
    }
</style>
