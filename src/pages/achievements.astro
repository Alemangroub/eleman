---
import Layout from '../layouts/Layout.astro';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Achievements from '../components/Achievements.astro';
import Footer from '../components/Footer.astro';
import FloatingButton from '../components/FloatingButton.astro';

const philosophyContent = {
    p1: "تأسست شركة الإيمان للتطوير والاستثمار العقاري ككيان طموح يهدف إلى ترك بصمة معمارية وحضارية مميزة في قلب صعيد مصر. منذ انطلاقتنا، وضعنا نصب أعيننا مهمة واضحة: تطوير مشاريع عقارية لا تقتصر على كونها مجرد مبانٍ، بل تمثل مجتمعات سكنية وتجارية متكاملة تنبض بالحياة وتوفر بيئة مثالية للعيش والعمل والاستثمار.",
    p2: "نحن نؤمن بأن التنمية الحقيقية تبدأ من فهم عميق لاحتياجات المجتمع المحلي وتطلعاته. لذلك، ترتكز استراتيجيتنا على اختيار المواقع الحيوية والمستقبلية، وتطبيق أحدث المفاهيم الهندسية، مع الحفاظ على الهوية الثقافية التي تميز صعيد مصر. من خلال الجمع بين الأصالة والمعاصرة، نقدم لعملائنا منتجًا عقاريًا فريدًا يضمن لهم حياة كريمة ومستقبلًا واعدًا."
};

const impactContent = {
    p1: "كل رقم في إنجازاتنا يروي قصة أعمق من مجرد إحصائية. فالمشاريع التي نطورها لا تقاس فقط بعددها، بل بحجم الفرص التي تخلقها لأبناء مجتمعنا في صعيد مصر. كل مشروع هو محرك صغير للاقتصاد المحلي، يوفر فرص عمل مباشرة وغير مباشرة، ويساهم في تنشيط السوق من خلال التعامل مع موردين ومقاولين محليين.",
    p2: "الوحدات السكنية التي نسلمها هي أكثر من مجرد جدران وأسقف؛ إنها منازل تحتضن أحلام الأسر، ومساحات تنشأ فيها علاقات الجيرة الطيبة. نحن لا نبني عقارات فحسب، بل نؤسس لمجتمعات متكاملة ومترابطة، ونساهم في رفع مستوى جودة الحياة من خلال توفير بنية تحتية عصرية وخدمات متكاملة، لنصنع أثرًا إيجابيًا يمتد لأجيال قادمة."
};
---
<Layout title="إنجازاتنا - شركة الإيمان">
  <TopBar />
  <Header showMenu={true} />

  <main class="achievements-page">
    <Achievements />

    <section class="our-philosophy">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">أساس نجاحنا: رؤية والتزام</h2>
          <p class="section-subtitle">أرقامنا لم تكن وليدة الصدفة، بل هي نتاج رؤية واضحة والتزام راسخ تجاه عملائنا ومجتمعنا.</p>
        </div>
        <div class="text-content-grid">
          <p>{philosophyContent.p1}</p>
          <p>{philosophyContent.p2}</p>
        </div>
      </div>
    </section>

    <section class="our-impact">
      <div class="container">
        <div class="section-header">
          <h2 class="section-title">أثرنا في المجتمع: أبعد من مجرد أرقام</h2>
          <p class="section-subtitle">نحن نؤمن بأن النجاح الحقيقي يقاس بمدى الأثر الإيجابي الذي نتركه في حياة الناس والمجتمع.</p>
        </div>
        <div class="text-content-grid">
            <p>{impactContent.p1}</p>
            <p>{impactContent.p2}</p>
        </div>
      </div>
    </section>

  </main>

  <Footer />
  <FloatingButton />
</Layout>

<style>
/* General Page Styles */
.achievements-page .section-header {
    margin-bottom: 60px;
}
.achievements-page .section-header .section-title {
    color: #2c3e50; 
}
.achievements-page .section-header .section-subtitle {
    color: #5a6878;
}
.achievements-page > section:not(:first-child) .container {
    position: static;
    z-index: 0;
}
.achievements-page .achievements {
    margin-bottom: 0;
    border-bottom: 1px solid #eee; /* Softer separator line */
}

/* Common styles for text-based sections */
.our-philosophy, .our-impact {
    padding: 100px 0;
    direction: rtl;
}

.our-philosophy {
    background-color: #fff;
}

.our-impact {
    background-color: #f9fafb; /* Subtle background color for differentiation */
    border-top: 1px solid #eee;
}

/* New 2-column grid layout for text content */
.text-content-grid {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr; /* Default to 1 column on mobile */
    gap: 30px;
}

.text-content-grid p {
    font-family: 'Almarai', sans-serif;
    font-size: 1.1rem;
    color: #34495e;
    line-height: 1.9;
    margin: 0;
}

/* Apply 2-column layout on tablets and desktops */
@media (min-width: 768px) {
    .text-content-grid {
        grid-template-columns: 1fr 1fr;
        gap: 50px; /* Wider gap for desktop */
    }
    .text-content-grid p {
        font-size: 1.15rem;
    }
}

/* Responsive adjustments for mobile */
@media (max-width: 767px) {
    .our-philosophy, .our-impact {
        padding: 60px 25px; /* Increased side padding for mobile */
    }
    .achievements-page .section-header {
        margin-bottom: 40px;
    }
}
</style>
