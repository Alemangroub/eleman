                        </div>
                        <div class="log-detail-item-full">
                            <dt>السبب</dt>
                            <dd data-key="notes"></dd>
                        </div>
                    </dl>
                </div>
                <div class="log-card-actions">
                    <button class="btn-action btn-edit">تعديل</button>
                    <button class="btn-action btn-delete">حذف</button>
                </div>
            </div>
        </template>

        <template id="simple-log-card-template">
            <div class="log-card">
                <div class="log-card-header">
                    <span class="log-action-type"></span>
                    <span class="log-date"></span>
                </div>
                <div class="log-card-body">
                    <dl class="log-details-list">
                        <div class="log-detail-item">
                            <dt>الكمية</dt>
                            <dd data-key="quantity"></dd>
                        </div>
                        <div class="log-detail-item">
                            <dt>المشرف</dt>
                            <dd data-key="supervisor"></dd>
                        </div>
                        <div class="log-detail-item-full">
                            <dt>السبب</dt>
                            <dd data-key="notes"></dd>
                        </div>
                    </dl>
                </div>
                <div class="log-card-actions">
                    <button class="btn-action btn-edit">تعديل</button>
                    <button class="btn-action btn-delete">حذف</button>
                </div>
            </div>
        </template>

    </main>
</Layout>

<script>
    import { initializeAuthCheck } from '../../../../scripts/auth/remains-auth.ts';

    const LOG_LIMIT = 3;
    let supervisorMap = {};
    let userIsAdmin = false;
    let allLogs = { iron: [], cement: [], other: [] };
    let currentFilters = { iron: 'all', other: 'all' };
    let docIdToDelete = null;

    let liveTotals = {
        iron: { '3': 0, '4': 0, '5': 0, stirrups6: 0, stirrups8: 0 },
        cement: 0,
        other: { sapa: 0, liquids: 0, misc: 0 }
    };

    const standardSubTypes = {
        iron: ["حديد 3 لينه", "حديد 4 لينه", "حديد 5 لينه", "حديد كانات 6 مللي", "حديد كانات 8 مللي"],
        other: ["مواد صبة", "سوائل"]
    };
    const standardUnits = { 
        other: ["قطعة", "لتر"] 
    };

    function handleIronTypeChange(event) {
        const selectedValue = event.target.value;
        const form = event.target.closest('form');
        const quantityLabel = form.querySelector('.quantity-label');
        if (quantityLabel) {
            quantityLabel.textContent = selectedValue.includes('كانات') ? 'عدد الكانات' : 'عدد الأسياخ';
        }
    }

    async function setupMaterialSection(material, projectId, user, userRole) {
        const card = document.getElementById(`${material}-card`);
        if (!card) return;

        card.querySelectorAll('.toggle-btn').forEach(button => {
            button.addEventListener('click', (e) => {
                card.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
                (e.target as HTMLElement).classList.add('active');
                const formId = (e.target as HTMLElement).dataset.form;
                card.querySelectorAll('.material-form').forEach(form => {
                    (form as HTMLElement).style.display = form.id === formId ? 'flex' : 'none';
                });
            });
        });

        if (material === 'iron') {
            card.querySelectorAll('select[name="subType"]').forEach(select => {
                select.addEventListener('change', (e) => handleIronTypeChange(e));
                handleIronTypeChange({ target: select });
            });
        }

        await fetchLogs(material, projectId, userRole);

        if (userRole === 'admin') {
            card.addEventListener('click', handleAdminActions);
            document.getElementById(`show-all-${material}`)?.addEventListener('click', () => {
                if(material === 'cement') renderSimpleLog(material, true);
                else renderDetailedLog(material, true);
            });

            card.querySelectorAll(`.filter-btn[data-material="${material}"]`).forEach(btn => {
                btn.addEventListener('click', () => {
                    card.querySelectorAll(`.filter-btn[data-material="${material}"]`).forEach(b => b.classList.remove('active'));
                    btn.classList.add('active');
                    currentFilters[material] = (btn as HTMLElement).dataset.filterValue;
                    renderDetailedLog(material);
                });
            });
        }

        if (userRole === 'admin' || userRole === 'supervisor') {
            const addForm = card.querySelector(`#add-${material}-form`) as HTMLFormElement;
            const dispenseForm = card.querySelector(`#dispense-${material}-form`) as HTMLFormElement;
            if(addForm) setupForm(addForm, false, projectId, user, material);
            if(dispenseForm) setupForm(dispenseForm, true, projectId, user, material);
        }
    }

    async function fetchLogs(material, projectId, userRole) {
        try {
            const response = await fetch(`/api/remains?projectId=${projectId}&material=${material}`);
            if (response.ok) {
                const logs = await response.json();
                processLogs(material, logs, userRole);
            }
        } catch (error) {
            console.error(`Error fetching ${material} logs:`, error);
        }
    }

    function processLogs(material, logs, userRole) {
        allLogs[material] = logs;
        
        let simpleTotalAdded = 0;
        let simpleTotalDispensed = 0;

        if (material === 'iron') {
            liveTotals.iron = { '3': 0, '4': 0, '5': 0, stirrups6: 0, stirrups8: 0 };
            const mTotals = { '3': {a:0,d:0}, '4': {a:0,d:0}, '5': {a:0,d:0}, s6: {a:0,d:0}, s8: {a:0,d:0} };
            logs.forEach(d => {
                let k = d.subType === 'حديد 3 لينه' ? '3' : d.subType === 'حديد 4 لينه' ? '4' : d.subType === 'حديد 5 لينه' ? '5' : d.subType === 'حديد كانات 6 مللي' ? 's6' : 's8';
                liveTotals.iron[k==='s6'?'stirrups6':k==='s8'?'stirrups8':k] += d.quantity;
                if(d.quantity > 0) mTotals[k].a += d.quantity; else mTotals[k].d += Math.abs(d.quantity);
            });
            ['3','4','5','stirrups6','stirrups8'].forEach(k => {
                const ik = k==='stirrups6'?'s6':k==='stirrups8'?'s8':k;
                document.getElementById(`iron-total-${k}`).textContent = liveTotals.iron[k];
                document.getElementById(`iron-added-${k}`).textContent = mTotals[ik].a;
                document.getElementById(`iron-dispensed-${k}`).textContent = mTotals[ik].d;
            });
        } else if (material === 'other') {
            liveTotals.other = { sapa: 0, liquids: 0, misc: 0 };
            logs.forEach(d => {
                const k = d.subType === 'مواد صبة' ? 'sapa' : d.subType === 'سوائل' ? 'liquids' : 'misc';
                liveTotals.other[k] += d.quantity;
                if(d.quantity > 0) simpleTotalAdded += d.quantity; else simpleTotalDispensed += Math.abs(d.quantity);
            });
            ['sapa','liquids','misc'].forEach(k => document.getElementById(`other-total-${k}`).textContent = liveTotals.other[k]);
            document.getElementById('other-total-added').textContent = simpleTotalAdded;
            document.getElementById('other-total-dispensed').textContent = simpleTotalDispensed;
        } else {
            liveTotals.cement = 0;
            logs.forEach(d => {
                liveTotals.cement += d.quantity;
                if(d.quantity > 0) simpleTotalAdded += d.quantity; else simpleTotalDispensed += Math.abs(d.quantity);
            });
            document.getElementById('cement-total').textContent = liveTotals.cement;
            document.getElementById('cement-total-added').textContent = simpleTotalAdded;
            document.getElementById('cement-total-dispensed').textContent = simpleTotalDispensed;
        }

        if (userRole === 'admin') {
            if(material === 'cement') renderSimpleLog(material);
            else renderDetailedLog(material); 
        }
    }

    function setupForm(form, isDispense, projectId, user, material) {
        if (!form) return;
        form.addEventListener('submit', (e) => handleFormSubmit(e, isDispense, projectId, user, material));
        if (material === 'other') setupConditionalFields(form);
    }

    function setupConditionalFields(form) {
        const subSel = form.querySelector('.subType-select') as HTMLSelectElement;
        const subInp = form.querySelector('input[name="customSubType"]') as HTMLInputElement;
        const unitSel = form.querySelector('.unit-select') as HTMLSelectElement;
        const unitInp = form.querySelector('input[name="customUnit"]') as HTMLInputElement;
        if(subSel && subInp) subSel.addEventListener('change', () => subInp.parentElement.style.display = subSel.value === 'أخرى' ? 'block' : 'none');
        if(unitSel && unitInp) unitSel.addEventListener('change', () => unitInp.parentElement.style.display = unitSel.value === 'أخرى' ? 'block' : 'none');
    }

    function renderDetailedLog(material, showAll = false) {
        const container = document.getElementById(`${material}-log-container`);
        const template = document.getElementById('detailed-log-card-template') as HTMLTemplateElement;
        if (!container || !template) return;
        let entries = allLogs[material];
        const f = currentFilters[material];
        if(f !== 'all') entries = entries.filter(e => f === 'أخرى' ? !standardSubTypes[material].includes(e.subType) : e.subType === f);
        
        container.innerHTML = '';
        entries.slice(0, showAll ? undefined : LOG_LIMIT).forEach(entry => {
            const clone = template.content.cloneNode(true) as HTMLElement;
            const isAdd = entry.quantity > 0;
            const card = clone.querySelector('.log-card');
            card.classList.add(isAdd ? 'log-card-add' : 'log-card-dispense');
            clone.querySelector('.log-action-type').textContent = isAdd ? 'إضافة' : 'صرف';
            clone.querySelector('.log-date').textContent = new Date(entry.createdAt).toLocaleString('ar-EG');
            clone.querySelector('[data-key="subType"]').textContent = entry.subType;
            clone.querySelector('[data-key="quantity"]').textContent = `${Math.abs(entry.quantity)} ${entry.subType.includes('كانات') ? 'كانة' : 'سيخ'}`;
            clone.querySelector('[data-key="supervisor"]').textContent = entry.supervisorName || [entry.supervisorId] || 'غير معروف';
            clone.querySelector('[data-key="notes"]').textContent = entry.notes || '-';
            if(userIsAdmin) {
                const eb = clone.querySelector('.btn-edit') as any; eb.dataset.id = entry.id; eb.dataset.material = material;
                const db = clone.querySelector('.btn-delete') as any; db.dataset.id = entry.id; db.dataset.material = material;
            } else clone.querySelector('.log-card-actions')?.remove();
            container.appendChild(clone);
        });
    }

    function renderSimpleLog(material, showAll = false) {
        const container = document.getElementById(`${material}-log-container`);
        const template = document.getElementById('simple-log-card-template') as HTMLTemplateElement;
        if (!container || !template) return;
        container.innerHTML = '';
        allLogs[material].slice(0, showAll ? undefined : LOG_LIMIT).forEach(entry => {
            const clone = template.content.cloneNode(true) as HTMLElement;
            const isAdd = entry.quantity > 0;
            clone.querySelector('.log-card').classList.add(isAdd ? 'log-card-add' : 'log-card-dispense');
            clone.querySelector('.log-action-type').textContent = isAdd ? 'إضافة' : 'صرف';
            clone.querySelector('.log-date').textContent = new Date(entry.createdAt).toLocaleString('ar-EG');
            clone.querySelector('[data-key="quantity"]').textContent = `${Math.abs(entry.quantity)} شكارة`;
            clone.querySelector('[data-key="supervisor"]').textContent = entry.supervisorName || [entry.supervisorId] || 'غير معروف';
            clone.querySelector('[data-key="notes"]').textContent = entry.notes || '-';
            if(userIsAdmin) {
                const eb = clone.querySelector('.btn-edit') as any; eb.dataset.id = entry.id; eb.dataset.material = material;
                const db = clone.querySelector('.btn-delete') as any; db.dataset.id = entry.id; db.dataset.material = material;
            } else clone.querySelector('.log-card-actions')?.remove();
            container.appendChild(clone);
        });
    }

    async function handleFormSubmit(e, isDisp, projId, user, mat) {
        e.preventDefault();
        const f = e.target as any;
        const q = parseInt(f.quantity.value);
        if(isDisp) {
            let stock = mat === 'iron' ? liveTotals.iron[f.subType.value.includes('3')?'3':f.subType.value.includes('4')?'4':f.subType.value.includes('5')?'5':f.subType.value.includes('6')?'stirrups6':'stirrups8'] : mat === 'cement' ? liveTotals.cement : liveTotals.other[f.subType.value === 'مواد صبة' ? 'sapa' : f.subType.value === 'سوائل' ? 'liquids' : 'misc'];
            if(q > stock) return alert('الكمية غير متوفرة');
        }
        const b = f.querySelector('button[type="submit"]');
        b.disabled = true;
        try {
            const res = await fetch('/api/remains', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    projectId: projId, material: mat, quantity: isDisp ? -q : q,
                    notes: f.notes.value, supervisorId: user.userId,
                    subType: f.subType?.value === 'أخرى' ? f.customSubType.value : f.subType?.value,
                    unit: f.unit?.value === 'أخرى' ? f.customUnit.value : f.unit?.value
                })
            });
            if(!res.ok) throw new Error();
            f.reset();
            alert('تمت العملية');
            await fetchLogs(mat, projId, userIsAdmin ? 'admin' : 'supervisor');
        } catch(err) { alert('فشل الحفظ'); } finally { b.disabled = false; }
    }

    function handleAdminActions(e) {
        const t = e.target.closest('button.btn-action'); if(!t) return;
        const id = t.dataset.id, m = t.dataset.material;
        if(t.classList.contains('btn-delete')) {
            docIdToDelete = id;
            document.getElementById('delete-confirm-modal').style.display = 'flex';
        } else openEditModal(id, m);
    }

    function openEditModal(id, m) {
        const e = allLogs[m].find(l => l.id === id); if(!e) return;
        const f = document.getElementById('edit-form') as any;
        f.docId.value = id; f.material.value = m; f.quantity.value = Math.abs(e.quantity); f.notes.value = e.notes;
        document.getElementById('edit-modal').style.display = 'flex';
    }

    async function initializeRemainsPage(user, userRole) {
        const pc = document.getElementById('page-content');
        if(!pc || pc.dataset.projectExists !== 'true') return;
        userIsAdmin = userRole === 'admin';
        const pid = pc.dataset.projectId;
        await setupMaterialSection('iron', pid, user, userRole);
        await setupMaterialSection('cement', pid, user, userRole);
        await setupMaterialSection('other', pid, user, userRole);
    }

    document.getElementById('confirm-delete-btn')?.addEventListener('click', async () => {
        await fetch(`/api/remains/${docIdToDelete}`, { method: 'DELETE' });
        location.reload();
    });

    document.getElementById('edit-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const f = e.target as any;
        await fetch(`/api/remains/${f.docId.value}`, {
            method: 'PUT',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ notes: f.notes.value, quantity: parseInt(f.quantity.value) })
        });
        location.reload();
    });

    initializeAuthCheck(initializeRemainsPage);
</script>

<style>
:root {
