.admin-only { padding-top: 1.5rem; }
.log-section h4 { font-size: 1.3rem; margin-bottom: 1rem; font-weight: 700; border-bottom: 1px solid var(--border-color); padding-bottom: 0.75rem; }
.log-container { display: grid; grid-template-columns: 1fr; gap: 1rem; }
.log-empty { text-align: center; padding: 1.5rem; color: var(--text-light); background-color: #f8f9fa; border-radius: 8px; }

.log-card { border-radius: 10px; border: 1px solid var(--border-color); background-color: white; box-shadow: 0 2px 8px rgba(0,0,0,0.04); overflow: hidden; transition: box-shadow 0.2s;}
