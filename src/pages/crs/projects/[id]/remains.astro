---
import Layout from '../../../../layouts/Layout.astro';
import { db } from "../../../../firebase/admin";

export const prerender = false;

const { id } = Astro.params;
let project = null;

try {
    const projectDoc = await db.collection('projects').doc(id).get();
    if (projectDoc.exists) {
        const projectData = projectDoc.data();
        project = { 
            id: projectDoc.id, 
            projectName: projectData.projectName || 'اسم غير متوفر',
            supervisorIds: projectData.supervisorIds || [] 
        };
    } else {
       // Let the frontend handle the not found case
    }
} catch (error) {
    console.error("Error fetching project data in remains.astro:", error);
    project = null;
}

---

<Layout title={`بواقي مشروع: ${project ? project.projectName : 'غير متوفر'}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <main 
        id="page-content" 
        class="remains-page" 
        style="display: none;" 
        data-project-id={project?.id}
        data-project-exists={project !== null}
        data-supervisor-ids={JSON.stringify(project?.supervisorIds || [])}
    >
         <div class="container">
            {project ? (
                <>
                    <header class="page-header">
                        <div>
                            <h1>بواقي مشروع: {project.projectName}</h1>
                            <p class="page-subtitle">صفحة مخصصة لإدارة البواقي للمشرف والأدمن.</p>
                        </div>
                        <a href={`/crs/projects/${id}`} class="back-link">&larr; العودة لتفاصيل المشروع</a>
                    </header>

                    <section class="materials-section">
                        <!-- Iron Card -->
                        <div class="material-card" id="iron-card">
                            <div class="card-header">
                                <h3>الحديد (بالسيخ)</h3>
                                <div class="iron-totals-grid">
                                    <div class="total-amount-display-small">
                                        <span>3 لينه:</span>
                                        <span id="iron-total-3">0</span>
                                    </div>
                                    <div class="total-amount-display-small">
                                        <span>4 لينه:</span>
                                        <span id="iron-total-4">0</span>
                                    </div>
                                    <div class="total-amount-display-small">
                                        <span>5 لينه:</span>
                                        <span id="iron-total-5">0</span>
                                    </div>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-iron-form">إضافة كمية</button>
                                        <button class="toggle-btn" data-form="dispense-iron-form">صرف كمية</button>
                                    </div>

                                    <form id="add-iron-form" class="material-form">
                                        <h4>إضافة عدد أسياخ</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="add-iron-type">نوع الحديد</label>
                                                <select id="add-iron-type" name="ironType" required>
                                                    <option value="حديد 3 لينه">حديد 3 لينه</option>
                                                    <option value="حديد 4 لينه">حديد 4 لينه</option>
                                                    <option value="حديد 5 لينه">حديد 5 لينه</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label for="add-iron-quantity">عدد الأسياخ</label>
                                                <input type="number" id="add-iron-quantity" name="quantity" step="1" required placeholder="150">
                                            </div>
                                        </div>
                                        <div class="form-group" style="width: 100%;">
                                            <label for="add-iron-notes">السبب</label>
                                            <input type="text" id="add-iron-notes" name="notes" required placeholder="مثال: توريد للمخزون">
                                        </div>
                                        <button type="submit" class="btn-submit">إضافة</button>
                                    </form>

                                    <form id="dispense-iron-form" class="material-form" style="display: none;">
                                        <h4>صرف عدد أسياخ</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="dispense-iron-type">نوع الحديد</label>
                                                <select id="dispense-iron-type" name="ironType" required>
                                                    <option value="حديد 3 لينه">حديد 3 لينه</option>
                                                    <option value="حديد 4 لينه">حديد 4 لينه</option>
                                                    <option value="حديد 5 لينه">حديد 5 لينه</option>
                                                </select>
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-iron-quantity">عدد الأسياخ</label>
                                                <input type="number" id="dispense-iron-quantity" name="quantity" step="1" required placeholder="50">
                                            </div>
                                        </div>
                                        <div class="form-group" style="width: 100%;">
                                            <label for="dispense-iron-notes">السبب</label>
                                            <input type="text" id="dispense-iron-notes" name="notes" required placeholder="مثال: أعمدة الدور الأول">
                                        </div>
                                        <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل حديد 3 لينه</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>العملية</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="iron-log-body-3"></tbody>
                                            </table>
                                        </div>
                                        <p id="iron-log-empty-3" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-iron-3" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                     <div class="log-section">
                                        <h4>سجل حديد 4 لينه</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>العملية</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="iron-log-body-4"></tbody>
                                            </table>
                                        </div>
                                        <p id="iron-log-empty-4" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-iron-4" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                     <div class="log-section">
                                        <h4>سجل حديد 5 لينه</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>العملية</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="iron-log-body-5"></tbody>
                                            </table>
                                        </div>
                                        <p id="iron-log-empty-5" class="log-empty">لا توجد سجلات.</p>
                                        <button id="show-all-iron-5" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Cement Card -->
                        <div class="material-card" id="cement-card">
                            <div class="card-header">
                                <h3>الأسمنت (بالشكارة)</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="cement-total">جاري التحميل...</span>
                                </div>
                            </div>
                            <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-cement-form">إضافة كمية</button>
                                        <button class="toggle-btn" data-form="dispense-cement-form">صرف كمية</button>
                                    </div>
                                    <form id="add-cement-form" class="material-form">
                                        <h4>إضافة كمية جديدة</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="add-cement-quantity">الكمية (شكارة)</label>
                                                <input type="number" id="add-cement-quantity" name="quantity" step="1" required placeholder="50">
                                            </div>
                                            <div class="form-group">
                                                <label for="add-cement-notes">السبب</label>
                                                <input type="text" id="add-cement-notes" name="notes" required placeholder="السبب">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit">إضافة</button>
                                    </form>
                                    <form id="dispense-cement-form" class="material-form" style="display: none;">
                                        <h4>صرف كمية مستخدمة</h4>
                                        <div class="form-row">
                                             <div class="form-group">
                                                <label for="dispense-cement-quantity">الكمية (شكارة)</label>
                                                <input type="number" id="dispense-cement-quantity" name="quantity" step="1" required placeholder="10">
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-cement-notes">السبب</label>
                                                <input type="text" id="dispense-cement-notes" name="notes" required placeholder="السبب">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                    <div class="log-section">
                                        <h4>سجل الإضافات</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="cement-add-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="cement-add-log-empty" class="log-empty">لا توجد سجلات إضافات.</p>
                                        <button id="show-all-cement-add" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                    <div class="log-section">
                                        <h4>سجل الصرف</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="cement-dispense-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="cement-dispense-log-empty" class="log-empty">لا توجد سجلات صرف.</p>
                                        <button id="show-all-cement-dispense" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- Other Card -->
                        <div class="material-card" id="other-card">
                            <div class="card-header">
                                <h3>أخرى</h3>
                                <div class="total-amount-display">
                                    <span>الكمية الحالية:</span>
                                    <span id="other-total">جاري التحميل...</span>
                                </div>
                            </div>
                           <div class="card-body">
                                <div class="supervisor-only" style="display: none;">
                                    <div class="form-toggle-buttons">
                                        <button class="toggle-btn active" data-form="add-other-form">إضافة كمية</button>
                                        <button class="toggle-btn" data-form="dispense-other-form">صرف كمية</button>
                                    </div>
                                    <form id="add-other-form" class="material-form">
                                        <h4>إضافة بند جديد</h4>
                                         <div class="form-row">
                                            <div class="form-group">
                                                <label for="add-other-quantity">الكمية</label>
                                                <input type="number" id="add-other-quantity" name="quantity" step="1" required placeholder="10">
                                            </div>
                                            <div class="form-group">
                                                <label for="add-other-notes">السبب</label>
                                                <input type="text" id="add-other-notes" name="notes" required placeholder="السبب">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit">إضافة</button>
                                    </form>
                                    <form id="dispense-other-form" class="material-form" style="display: none;">
                                        <h4>صرف بند</h4>
                                        <div class="form-row">
                                            <div class="form-group">
                                                <label for="dispense-other-quantity">الكمية المصروفة</label>
                                                <input type="number" id="dispense-other-quantity" name="quantity" step="1" required placeholder="2">
                                            </div>
                                            <div class="form-group">
                                                <label for="dispense-other-notes">السبب</label>
                                                <input type="text" id="dispense-other-notes" name="notes" required placeholder="السبب">
                                            </div>
                                        </div>
                                        <button type="submit" class="btn-submit btn-dispense">صرف</button>
                                    </form>
                                </div>
                                <div class="admin-only" style="display: none;">
                                   <div class="log-section">
                                        <h4>سجل الإضافات</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="other-add-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="other-add-log-empty" class="log-empty">لا توجد سجلات إضافات.</p>
                                        <button id="show-all-other-add" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                    <div class="log-section">
                                        <h4>سجل الصرف</h4>
                                        <div class="table-container">
                                            <table>
                                                <thead><tr><th>التاريخ</th><th>الكمية</th><th>المشرف</th><th>السبب</th></tr></thead>
                                                <tbody id="other-dispense-log-body"></tbody>
                                            </table>
                                        </div>
                                        <p id="other-dispense-log-empty" class="log-empty">لا توجد سجلات صرف.</p>
                                        <button id="show-all-other-dispense" class="btn-show-all" style="display:none;">عرض الكل</button>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </section>
                </>
            ) : (
                <div class="error-card">
                    <h2>خطأ في تحميل البيانات</h2>
                    <p>تعذر العثور على المشروع المطلوب أو حدث خطأ أثناء تحميله. يرجى التأكد من صحة الرابط.</p>
                     <a href="/crs/projects" class="back-link">العودة إلى قائمة المشاريع</a>
                </div>
            )}
        </div>
    </main>
</Layout>

<script>
    import { initializeAuthCheck } from '../../../../scripts/auth/remains-auth.ts';
    import { db } from '../../../../firebase/client';
    import { collection, addDoc, query, where, onSnapshot, serverTimestamp, orderBy, doc, getDoc } from 'firebase/firestore';

    const LOG_LIMIT = 5;
    let supervisorMap = {};

    // --- IRON SECTION --- //
    let allIronLogs = { '3': [], '4': [], '5': [] };

    function setupIronSection(projectId, user, userRole) {
        const card = document.getElementById('iron-card');
        if (!card) return;

        const total3El = card.querySelector('#iron-total-3');
        const total4El = card.querySelector('#iron-total-4');
        const total5El = card.querySelector('#iron-total-5');
        
        const addForm = card.querySelector('#add-iron-form');
        const dispenseForm = card.querySelector('#dispense-iron-form');
        const toggleButtons = card.querySelectorAll('.toggle-btn');

        toggleButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                const parentCard = e.target.closest('.material-card');
                parentCard.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
                e.target.classList.add('active');
                const formId = e.target.dataset.form;
                parentCard.querySelectorAll('.material-form').forEach(form => {
                    form.style.display = form.id === formId ? 'flex' : 'none';
                });
            });
        });

        const remainsQuery = query(
            collection(db, 'remains'),
            where("projectId", "==", projectId),
            where("material", "==", "iron"),
            orderBy("createdAt", "desc")
        );

        onSnapshot(remainsQuery, (snapshot) => {
            let total3 = 0, total4 = 0, total5 = 0;
            const logs3 = [], logs4 = [], logs5 = [];

            snapshot.forEach(doc => {
                const data = doc.data();
                switch(data.ironType) {
                    case 'حديد 3 لينه': total3 += data.quantity; logs3.push(data); break;
                    case 'حديد 4 لينه': total4 += data.quantity; logs4.push(data); break;
                    case 'حديد 5 لينه': total5 += data.quantity; logs5.push(data); break;
                }
            });

            total3El.textContent = `${total3} سيخ`;
            total4El.textContent = `${total4} سيخ`;
            total5El.textContent = `${total5} سيخ`;

            if (userRole === 'admin') {
                allIronLogs = { '3': logs3, '4': logs4, '5': logs5 };
                updateUnifiedIronLogTable('3');
                updateUnifiedIronLogTable('4');
                updateUnifiedIronLogTable('5');
            }
        }, (error) => {
            console.error(`Error fetching iron data:`, error);
            [total3El, total4El, total5El].forEach(el => el.textContent = "خطأ");
        });

        if (userRole === 'supervisor') {
            setupIronFormSubmission(addForm, false, projectId, user);
            setupIronFormSubmission(dispenseForm, true, projectId, user);
        }
    }

    function renderIronLogEntries(entries) {
        return entries.map(entry => {
            const supervisorName = entry.supervisorName || supervisorMap[entry.supervisorId] || 'مشرف غير معروف';
            return `
                <tr>
                    <td>${entry.createdAt?.toDate().toLocaleDateString('ar-EG') || ''}</td>
                    <td class="${entry.quantity > 0 ? 'text-success' : 'text-danger'}">${entry.quantity > 0 ? 'إضافة' : 'صرف'}</td>
                    <td>${Math.abs(entry.quantity)}</td>
                    <td>${supervisorName}</td>
                    <td>${entry.notes || '-'}</td>
                </tr>
            `}).join('');
    }

    function updateUnifiedIronLogTable(type, showAll = false) {
        const tbody = document.getElementById(`iron-log-body-${type}`);
        const emptyMsg = document.getElementById(`iron-log-empty-${type}`);
        const showAllBtn = document.getElementById(`show-all-iron-${type}`);
        const entries = allIronLogs[type];

        if (!tbody || !emptyMsg || !showAllBtn) return;

        emptyMsg.style.display = entries.length === 0 ? 'block' : 'none';
        
        if (entries.length > LOG_LIMIT && !showAll) {
            tbody.innerHTML = renderIronLogEntries(entries.slice(0, LOG_LIMIT));
            showAllBtn.style.display = 'block';
        } else {
            tbody.innerHTML = renderIronLogEntries(entries);
            showAllBtn.style.display = 'none';
        }
    }

    document.getElementById('show-all-iron-3').addEventListener('click', () => updateUnifiedIronLogTable('3', true));
    document.getElementById('show-all-iron-4').addEventListener('click', () => updateUnifiedIronLogTable('4', true));
    document.getElementById('show-all-iron-5').addEventListener('click', () => updateUnifiedIronLogTable('5', true));

    async function handleIronFormSubmit(e, isDispense, projectId, user) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = form.querySelector('button[type="submit"]');
        submitBtn.disabled = true;
        submitBtn.textContent = 'جارٍ الحفظ...';

        try {
            let quantity = parseInt(form.quantity.value, 10);
            if (isNaN(quantity) || quantity <= 0) throw new Error('يرجى إدخال كمية موجبة صحيحة.');
            
            const ironType = form.ironType.value;
            if (!ironType) throw new Error('يرجى اختيار نوع الحديد.');

            await addDoc(collection(db, 'remains'), {
                projectId, material: 'iron', ironType, 
                quantity: isDispense ? -quantity : quantity,
                notes: form.notes.value,
                supervisorId: user.uid,
                supervisorName: user.displayName || 'مشرف',
                createdAt: serverTimestamp()
            });

            form.reset();
            alert('تمت العملية بنجاح!');
        } catch (error) {
            console.error(`Error submitting iron form:`, error);
            alert(error.message || 'حدث خطأ أثناء الحفظ.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = isDispense ? 'صرف' : 'إضافة';
        }
    }

    function setupIronFormSubmission(form, isDispense, projectId, user) {
        if (form) {
            form.addEventListener('submit', (e) => handleIronFormSubmit(e, isDispense, projectId, user));
        }
    }

    // --- GENERIC MATERIAL SECTION --- //
    let allGenericLogs = {}; 

    function setupMaterialSection(material, unit, projectId, user, userRole, isInteger = false) {
        const card = document.getElementById(`${material}-card`);
        if (!card) return;

        allGenericLogs[material] = { add: [], dispense: [] };

        const totalEl = card.querySelector(`#${material}-total`);
        const addForm = card.querySelector(`#add-${material}-form`);
        const dispenseForm = card.querySelector(`#dispense-${material}-form`);
        const toggleButtons = card.querySelectorAll('.toggle-btn');

        toggleButtons.forEach(button => {
            button.addEventListener('click', (e) => {
                const parentCard = e.target.closest('.material-card');
                parentCard.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
                e.target.classList.add('active');
                const formId = e.target.dataset.form;
                parentCard.querySelectorAll('.material-form').forEach(form => {
                    form.style.display = form.id === formId ? 'flex' : 'none';
                });
            });
        });

        const remainsQuery = query(collection(db, 'remains'), where("projectId", "==", projectId), where("material", "==", material), orderBy("createdAt", "desc"));

        onSnapshot(remainsQuery, (snapshot) => {
            let totalAmount = 0;
            const addLogEntries = [], dispenseLogEntries = [];

            snapshot.forEach(doc => {
                const data = doc.data();
                totalAmount += data.quantity;
                if (data.quantity > 0) addLogEntries.push(data);
                else if (data.quantity < 0) dispenseLogEntries.push(data);
            });

            totalEl.textContent = `${isInteger ? totalAmount : totalAmount.toFixed(2)} ${unit}`;

            if (userRole === 'admin') {
                allGenericLogs[material] = { add: addLogEntries, dispense: dispenseLogEntries };
                updateGenericLogTable(material, 'add');
                updateGenericLogTable(material, 'dispense');
            }
        }, (error) => {
            console.error(`Error fetching ${material} data:`, error);
            totalEl.textContent = "خطأ";
        });

        if (userRole === 'supervisor') {
            setupGenericFormSubmission(addForm, false, material, projectId, user, isInteger);
            setupGenericFormSubmission(dispenseForm, true, material, projectId, user, isInteger);
        }
    }
    
    function renderGenericLogEntries(entries, isDispense) {
        return entries.map(entry => {
            const supervisorName = entry.supervisorName || supervisorMap[entry.supervisorId] || 'مشرف غير معروف';
            return `
                <tr>
                    <td>${entry.createdAt?.toDate().toLocaleDateString('ar-EG') || ''}</td>
                    <td>${isDispense ? Math.abs(entry.quantity) : entry.quantity}</td>
                    <td>${supervisorName}</td>
                    <td>${entry.notes || '-'}</td>
                </tr>
            `}).join('');
    }

    function updateGenericLogTable(material, type, showAll = false) {
        const tbody = document.getElementById(`${material}-${type}-log-body`);
        const emptyMsg = document.getElementById(`${material}-${type}-log-empty`);
        const showAllBtn = document.getElementById(`show-all-${material}-${type}`);
        const entries = allGenericLogs[material][type];

        if (!tbody || !emptyMsg || !showAllBtn) return;
        
        emptyMsg.style.display = entries.length === 0 ? 'block' : 'none';
        showAllBtn.style.display = entries.length > LOG_LIMIT && !showAll ? 'block' : 'none';

        const entriesToRender = showAll ? entries : entries.slice(0, LOG_LIMIT);
        tbody.innerHTML = renderGenericLogEntries(entriesToRender, type === 'dispense');
    }

    document.querySelectorAll('.btn-show-all').forEach(button => {
        const idParts = button.id.split('-');
        if (idParts[1] !== 'iron') {
             button.addEventListener('click', (e) => {
                const [_, material, type] = e.target.id.split('-');
                updateGenericLogTable(material, type, true);
            });
        }
    });

    async function handleGenericFormSubmit(e, isDispense, material, projectId, user, isInteger) {
        e.preventDefault();
        const form = e.target;
        const submitBtn = form.querySelector('button[type="submit"]');
        const originalBtnText = submitBtn.textContent;

        submitBtn.disabled = true;
        submitBtn.textContent = 'جارٍ الحفظ...';

        try {
            let quantity = isInteger ? parseInt(form.quantity.value, 10) : parseFloat(form.quantity.value);
            if (isNaN(quantity) || quantity <= 0) throw new Error('يرجى إدخال كمية موجبة صحيحة.');

            await addDoc(collection(db, 'remains'), {
                projectId, material,
                quantity: isDispense ? -quantity : quantity,
                notes: form.notes.value,
                supervisorId: user.uid,
                supervisorName: user.displayName || 'مشرف',
                createdAt: serverTimestamp()
            });

            form.reset();
            alert('تمت العملية بنجاح!');
        } catch (error) {
            console.error(`Error submitting ${material} form:`, error);
            alert(error.message || 'حدث خطأ أثناء الحفظ.');
        } finally {
            submitBtn.disabled = false;
            submitBtn.textContent = originalBtnText;
        }
    }

    function setupGenericFormSubmission(form, isDispense, material, projectId, user, isInteger) {
        if (form) {
            form.addEventListener('submit', (e) => handleGenericFormSubmit(e, isDispense, material, projectId, user, isInteger));
        }
    }

    // --- INITIALIZATION & HELPERS --- //

    async function getSupervisorNames(ids) {
        const nameMap = {};
        if (!ids || ids.length === 0) return nameMap;

        const userPromises = ids.map(id => getDoc(doc(db, 'users', id)));
        const userDocs = await Promise.all(userPromises);

        userDocs.forEach(userDoc => {
            if (userDoc.exists()) {
                nameMap[userDoc.id] = userDoc.data().displayName || 'اسم غير معروف';
            } else {
                nameMap[userDoc.id] = 'مشرف محذوف';
            }
        });
        return nameMap;
    }

    async function initializeRemainsPage(user, userRole) {
        const pageContent = document.getElementById('page-content');
        if (!pageContent || !pageContent.dataset.projectExists) return;

        const projectId = pageContent.dataset.projectId;
        const supervisorIds = JSON.parse(pageContent.dataset.supervisorIds || '[]');
        supervisorMap = await getSupervisorNames(supervisorIds);
        
        setupIronSection(projectId, user, userRole);
        setupMaterialSection('cement', 'شكارة', projectId, user, userRole, true);
        setupMaterialSection('other', 'وحدة', projectId, user, userRole, true);
    }

    initializeAuthCheck(initializeRemainsPage);

</script>

