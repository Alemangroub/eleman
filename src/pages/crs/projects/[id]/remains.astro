.log-card-body { padding: 1.25rem; }
.log-details-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem 1.5rem; margin: 0; padding: 0;}
.log-detail-item, .log-detail-item-full { display: flex; flex-direction: column; }
.log-detail-item dt, .log-detail-item-full dt { font-size: 0.85rem; font-weight: 600; color: var(--text-light); margin-bottom: 0.25rem; }
.log-detail-item dd, .log-detail-item-full dd { font-size: 1rem; font-weight: 500; color: var(--text-dark); margin: 0; }
.log-detail-item-full { grid-column: 1 / -1; }

.log-card-actions { padding: 0.75rem 1.25rem; background-color: #f9fafb; border-top: 1px solid var(--border-color); display: flex; justify-content: flex-end; gap: 0.5rem; }
.btn-action { background: none; border: 1px solid transparent; border-radius: 6px; cursor: pointer; padding: 0.3rem 0.6rem; margin: 0; font-weight: 600; font-size: 0.85rem;}
.btn-edit { color: var(--primary-color); border-color: var(--primary-color);}
.btn-edit:hover { background-color: #eef5ff; }
