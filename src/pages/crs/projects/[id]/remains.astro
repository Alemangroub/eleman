---
import Layout from '../../../../layouts/Layout.astro';
import prisma from "../../../../lib/prisma";

export const prerender = false;

const { id } = Astro.params;
if (!id) {
    return Astro.redirect('/404');
}

let project = null;

try {
    const projectDoc = await prisma.project.findUnique({
        where: { id: id },
        include: { supervisors: true }
    });
    
    if (projectDoc) {
        project = { 
            id: projectDoc.id, 
            projectName: projectDoc.projectName || 'اسم غير متوفر',
            supervisorIds: projectDoc.supervisors.map(s => s.userId)
        };
    } else {
       // Let the frontend handle the not found case
    }
} catch (error) {
    console.error("Error fetching project data in remains.astro:", error);
    project = null;
}

---

<Layout title={`بواقي مشروع: ${project ? project.projectName : 'غير متوفر'}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
