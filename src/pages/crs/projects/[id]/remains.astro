                                <option value="حديد 3 لينه">حديد 3 لينه</option>
                                <option value="حديد 4 لينه">حديد 4 لينه</option>
                                <option value="حديد 5 لينه">حديد 5 لينه</option>
                            </select>
                        </div>
                        <div class="form-group">
                             <label for="edit-length">الطول (بالمتر)</label>
                             <input type="number" id="edit-length" name="length" step="any" required>
                        </div>
