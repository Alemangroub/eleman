---
import Layout from '../../../../layouts/Layout.astro';
import AdminLogin from '../../../../components/AdminLogin.astro';
import prisma from "../../../../lib/prisma";

export const prerender = false;

const { id } = Astro.params;
if (!id) {
    return Astro.redirect('/404');
}

let project = null;

try {
    const projectDoc = await prisma.project.findUnique({
        where: { id: id }
    });
    
    if (projectDoc) {
        project = { 
            id: projectDoc.id, 
            projectName: projectDoc.projectName || 'اسم غير متوفر',
        };
    } else {
        return Astro.redirect('/404');
    }
} catch (error) {
    console.error("Error fetching project data in agreements.astro:", error);
    project = null;
}
---

<Layout title={`اتفاقات المشروع: ${project ? project.projectName : ''}`}>
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <div id="admin-login-container" class="auth-container" style="display: none;">
      <AdminLogin />
    </div>

    <main id="page-content" class="agreements-admin-page" style="display: none;" data-project-id={project?.id} data-project-name={project?.projectName}>
        <div class="container">
             {project ? (
                <>
                    <header class="page-header">
                        <div>
                            <h1>اتفاقات المشروع: {project.projectName}</h1>
                            <p class="page-subtitle">هنا يمكنك عرض وإدارة اتفاقات المشروع.</p>
                        </div>
                        <div class="header-actions">
                           <button id="add-agreement-btn" class="btn btn-primary">+ إضافة اتفاق جديد</button>
                           <a href={`/crs/projects/${id}`} class="btn btn-secondary">&larr; العودة للتفاصيل</a>
                        </div>
                    </header>

                    <div class="agreements-list-container">
                         <div class="list-controls">
                            <div class="filter-group">
                                <label for="category-filter">تصفية حسب البند الرئيسي:</label>
                                <select id="category-filter">
                                    <option value="" disabled selected>-- اختر بندًا لعرضه --</option>
                                    <option value="all">عرض الكل</option>
                                    <option value="المقاول">المقاول</option>
                                    <option value="المباني">المباني</option>
                                    <option value="الكهرباء">الكهرباء</option>
                                    <option value="السباكه">السباكه</option>
                                    <option value="المحاره">المحاره</option>
                                    <option value="الرخام">الرخام</option>
                                    <option value="الدهانات">الدهانات</option>
                                    <option value="اخري">اخري</option>
                                </select>
                            </div>
                            <div class="filter-group" id="subtype-filter-group" style="display: none;">
                                <label for="subtype-filter">تصفية حسب البند الفرعي:</label>
                                <select id="subtype-filter">
                                    <option value="all">كل بنود المقاول</option>
                                    <option value="لبشه مسلحه">لبشه مسلحه</option>
                                    <option value="لبشه عاديه">لبشه عاديه</option>
                                </select>
                            </div>
                        </div>
                        <div class="totals-summary-container">
                            <div class="total-box">
                                <span class="total-label">إجمالي المعروض</span>
                                <span id="filtered-agreements-total" class="total-value">0.00 ج.م</span>
                            </div>
                            <div class="total-box grand-total-box">
                                <span class="total-label">الإجمالي الكلي</span>
                                <span id="grand-agreements-total" class="total-value">0.00 ج.م</span>
                            </div>
                        </div>
                        <div id="agreements-grid" class="agreements-grid">
                            <!-- Agreement cards are injected by JS -->
                        </div>
                        <p id="no-agreements-message" style="display: none;">لم يتم إضافة أي اتفاقات لهذا المشروع بعد.</p>
                    </div>
                </>
            ) : (
                <div class="error-card">
                    <h2>خطأ في تحميل البيانات</h2>
                    <p>حدث خطأ حرج أثناء محاولة تحميل تفاصيل المشروع. برجاء المحاولة مرة أخرى لاحقاً.</p>
                    <a href="/crs/projects" class="back-link">العودة إلى قائمة المشاريع</a>
                </div>
            )}
        </div>
    </main>

    <!-- Modals (Add/Edit, Delete) -->
    <div id="agreement-modal" class="modal-overlay">
      <div class="modal-box">
        <h3 id="modal-title">إضافة اتفاق جديد</h3>
        <form id="agreement-form">
            <div class="form-group">
                <label for="agreement-title">بند الاتفاق</label>
                <select id="agreement-title" required>
                    <option value="" disabled selected>اختر بند الاتفاق</option>
                    <option value="المقاول">المقاول</option>
                    <option value="المباني">المباني</option>
                    <option value="الكهرباء">الكهرباء</option>
                    <option value="السباكه">السباكه</option>
                    <option value="المحاره">المحاره</option>
                    <option value="الرخام">الرخام</option>
                    <option value="الدهانات">الدهانات</option>
                    <option value="اخري">اخري</option>
                </select>
            </div>
            <div class="form-group" id="other-title-group" style="display: none;">
                <label for="other-agreement-title">بند آخر (اذكره)</label>
                <input type="text" id="other-agreement-title">
            </div>
             <div class="form-group" id="contractor-subtype-group" style="display: none;">
                <label for="contractor-subtype">نوع البند الفرعي</label>
                <select id="contractor-subtype">
                    <option value="" disabled selected>اختر النوع</option>
                    <option value="لبشه مسلحه">لبشه مسلحه</option>
                    <option value="لبشه عاديه">لبشه عاديه</option>
                </select>
            </div>
            <div class="form-group">
                <label for="agreed-with">اسم المتفق معه</label>
                <input type="text" id="agreed-with" required>
            </div>
            <div class="form-group">
                <label for="date">التاريخ</label>
                <input type="date" id="date" required>
            </div>
            <div id="contractor-fields" class="dynamic-fields" style="display: none;">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="area">المساحة (م²)</label>
                        <input type="number" id="area" step="any">
                    </div>
                    <div class="form-group">
                        <label for="price-per-meter">سعر المتر</label>
                        <input type="number" id="price-per-meter" step="any">
                    </div>
                </div>
            </div>
             <div id="generic-fields" class="dynamic-fields" style="display: none;">
                <div class="form-grid">
                    <div class="form-group">
                        <label for="quantity">الكمية</label>
                        <input type="number" id="quantity" step="any">
                    </div>
                    <div class="form-group">
                        <label for="price">السعر</label>
                        <input type="number" id="price" step="any">
                    </div>
                </div>
            </div>
             <div class="form-group">
                <label for="agreement-total">الإجمالي</label>
                <input type="number" id="agreement-total" required step="any">
            </div>
          <div class="form-group">
            <label for="agreement-details">تفاصيل الاتفاق</label>
            <textarea id="agreement-details" rows="4"></textarea>
          </div>
           <div class="form-group">
                <label for="agreement-notes">ملاحظات</label>
                <textarea id="agreement-notes" rows="3"></textarea>
            </div>
          <div class="modal-actions">
            <button type="button" id="cancel-agreement-btn" class="btn btn-secondary">إلغاء</button>
            <button type="submit" class="btn btn-primary">حفظ</button>
          </div>
        </form>
      </div>
    </div>
    <div id="delete-modal" class="modal-overlay">
      <div class="modal-box">
        <h3>تأكيد الحذف</h3>
        <p>هل أنت متأكد من أنك تريد حذف هذا الاتفاق؟</p>
        <div class="modal-actions">
          <button id="cancel-delete-btn" class="btn btn-secondary">إلغاء</button>
          <button id="confirm-delete-btn" class="btn btn-danger">تأكيد الحذف</button>
        </div>
      </div>
    </div>
</Layout>

<script>
    import { checkAuth, logout } from '../../../../lib/auth.js';
    import * as XLSX from 'xlsx';
    import html2canvas from 'html2canvas';
    import { jsPDF } from 'jspdf';

    let currentEditAgreementId = null;
    let allAgreementsData = [];
    const pageContent = document.getElementById('page-content');
    const projectId = pageContent?.dataset.projectId;
    const projectName = pageContent?.dataset.projectName;

    function toYYYYMMDD(date) {
        if (!date) return '';
        const d = new Date(date);
        return `${d.getFullYear()}-${String(d.getMonth() + 1).padStart(2, '0')}-${String(d.getDate()).padStart(2, '0')}`;
    }

    document.addEventListener('DOMContentLoaded', async () => {
        const authLoadingMessage = document.getElementById('auth-loading-message');
        const loginContainer = document.getElementById('admin-login-container');
        
        const user = await checkAuth();
        if(authLoadingMessage) authLoadingMessage.style.display = 'none';

        if (user && user.role === 'admin') {
            if(pageContent) pageContent.style.display = 'block';
            if(loginContainer) loginContainer.style.display = 'none';
            initializePage();
        } else {
            if(pageContent) pageContent.style.display = 'none';
            if(loginContainer) loginContainer.style.display = 'block';
        }
    });

    function initializePage() {
        if (!projectId) return;
        setupEventListeners();
        fetchAgreements();
    }

    function showModal(modal) { modal.classList.add('visible'); }
    function hideModal(modal) { modal.classList.remove('visible'); }

    function setupEventListeners() {
        const addAgreementBtn = document.getElementById('add-agreement-btn');
        const agreementModal = document.getElementById('agreement-modal');
        const deleteModal = document.getElementById('delete-modal');
        const agreementForm = document.getElementById('agreement-form');
        const agreementTitleSelect = document.getElementById('agreement-title') as HTMLSelectElement;
        const totalInput = document.getElementById('agreement-total') as HTMLInputElement;
        const areaInput = document.getElementById('area') as HTMLInputElement;
        const pricePerMeterInput = document.getElementById('price-per-meter') as HTMLInputElement;
        const quantityInput = document.getElementById('quantity') as HTMLInputElement;
        const priceInput = document.getElementById('price') as HTMLInputElement;
        const subtypeFilter = document.getElementById('subtype-filter') as HTMLSelectElement;
        const categoryFilter = document.getElementById('category-filter') as HTMLSelectElement;

        addAgreementBtn?.addEventListener('click', () => {
            currentEditAgreementId = null;
            document.getElementById('modal-title').textContent = 'إضافة اتفاق جديد';
            agreementForm?.reset();
            document.getElementById('date').value = new Date().toISOString().split('T')[0];
            agreementTitleSelect.dispatchEvent(new Event('change'));
            showModal(agreementModal);
        });

        document.getElementById('cancel-agreement-btn')?.addEventListener('click', () => hideModal(agreementModal));
        
        agreementTitleSelect?.addEventListener('change', () => {
            const title = agreementTitleSelect.value;
            const isContractor = title === 'المقاول';
            const isOther = title === 'اخري';
            const isGeneric = !isContractor && !isOther && title !== '';
            
            document.getElementById('other-title-group').style.display = isOther ? 'block' : 'none';
            document.getElementById('contractor-subtype-group').style.display = isContractor ? 'block' : 'none';
            document.getElementById('contractor-fields').style.display = isContractor ? 'block' : 'none';
            document.getElementById('generic-fields').style.display = (isGeneric || isOther) ? 'block' : 'none';
            
            totalInput.readOnly = isContractor || isGeneric || isOther;
        });

        function calculateTotal() {
            if (agreementTitleSelect.value === 'المقاول') {
                totalInput.value = ((parseFloat(areaInput.value) || 0) * (parseFloat(pricePerMeterInput.value) || 0)).toFixed(2);
            } else {
                totalInput.value = ((parseFloat(quantityInput.value) || 0) * (parseFloat(priceInput.value) || 0)).toFixed(2);
            }
        }
        [areaInput, pricePerMeterInput, quantityInput, priceInput].forEach(inp => inp?.addEventListener('input', calculateTotal));

        agreementForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const f = e.target as any;
            const selectedTitle = agreementTitleSelect.value;
            let finalTitle = selectedTitle;
            if(selectedTitle === 'اخري') finalTitle = f['other-agreement-title'].value;
            else if(selectedTitle === 'المقاول') finalTitle = f['contractor-subtype'].value;

            const data = {
                projectId,
                title: finalTitle,
                mainCategory: selectedTitle,
                agreedWith: f['agreed-with'].value,
                date: f.date.value,
                total: parseFloat(f['agreement-total'].value),
                details: f['agreement-details'].value,
                notes: f['agreement-notes'].value,
                area: parseFloat(f.area.value) || null,
                pricePerMeter: parseFloat(f['price-per-meter'].value) || null,
                quantity: parseFloat(f.quantity.value) || null,
                price: parseFloat(f.price.value) || null
            };

            try {
                const method = currentEditAgreementId ? 'PUT' : 'POST';
                const url = currentEditAgreementId ? `/api/agreements/${currentEditAgreementId}` : '/api/agreements';
                const res = await fetch(url, {
                    method,
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                if(res.ok) {
                    hideModal(agreementModal);
                    fetchAgreements();
                } else alert('خطأ في الحفظ');
            } catch(e) { console.error(e); }
        });

        categoryFilter?.addEventListener('change', () => {
            document.getElementById('subtype-filter-group').style.display = categoryFilter.value === 'المقاول' ? 'flex' : 'none';
            displayFilteredAgreements();
        });
        subtypeFilter?.addEventListener('change', displayFilteredAgreements);

        document.getElementById('agreements-grid')?.addEventListener('click', async (e) => {
            const btn = e.target.closest('button');
            if(!btn) return;
            const card = btn.closest('.agreement-card');
            const id = card.dataset.id;
            const data = JSON.parse(card.dataset.agreement);

            if(btn.classList.contains('btn-edit-custom')) openEditModal(id, data);
            else if(btn.classList.contains('btn-delete-custom')) {
                currentEditAgreementId = id;
                showModal(deleteModal);
            } else if(btn.classList.contains('btn-print-custom')) window.print();
            else if(btn.classList.contains('btn-pdf-custom')) exportToPDF(card, data);
            else if(btn.classList.contains('btn-excel-custom')) exportToExcel(data);
        });

        document.getElementById('confirm-delete-btn')?.addEventListener('click', async () => {
            await fetch(`/api/agreements/${currentEditAgreementId}`, { method: 'DELETE' });
            hideModal(deleteModal);
            fetchAgreements();
        });
        document.getElementById('cancel-delete-btn')?.addEventListener('click', () => hideModal(deleteModal));
    }

    async function fetchAgreements() {
        const res = await fetch(`/api/agreements?projectId=${projectId}`);
        if(res.ok) {
            allAgreementsData = await res.json();
            displayFilteredAgreements();
            updateTotals();
        }
    }

    function displayFilteredAgreements() {
        const cat = (document.getElementById('category-filter') as HTMLSelectElement).value;
        const sub = (document.getElementById('subtype-filter') as HTMLSelectElement).value;
        const grid = document.getElementById('agreements-grid');
        const msg = document.getElementById('no-agreements-message');

        let filtered = allAgreementsData;
        if(cat && cat !== 'all') filtered = filtered.filter(a => a.mainCategory === cat);
        if(cat === 'المقاول' && sub && sub !== 'all') filtered = filtered.filter(a => a.title === sub);

        if(grid) grid.innerHTML = filtered.map(renderAgreementCard).join('');
        if(msg) msg.style.display = filtered.length === 0 ? 'block' : 'none';
        updateTotals();
    }

    function renderAgreementCard(a) {
        const stored = {...a, date: toYYYYMMDD(a.date)};
        let calc = '';
        if(a.mainCategory === 'المقاول') {
            calc = `<div class="card-item"><strong>المساحة:</strong><span>${a.area || 0} م²</span></div>
                    <div class="card-item"><strong>سعر المتر:</strong><span>${(a.pricePerMeter || 0).toLocaleString()} ج.م</span></div>`;
        } else if(a.quantity) {
            calc = `<div class="card-item"><strong>الكمية:</strong><span>${a.quantity}</span></div>
                    <div class="card-item"><strong>السعر:</strong><span>${(a.price || 0).toLocaleString()} ج.م</span></div>`;
        }

        return `
            <div class="agreement-card" data-id="${a.id}" data-total="${a.total}" data-agreement='${JSON.stringify(stored)}'>
                <div class="card-header">
                    <h3>${a.title}</h3>
                    <div class="card-actions">
                        <button class="btn-icon btn-print-custom" title="طباعة"><i class="material-icons">print</i></button>
                        <button class="btn-icon btn-pdf-custom" title="تصدير PDF"><i class="material-icons">picture_as_pdf</i></button>
                        <button class="btn-icon btn-excel-custom" title="تصدير Excel"><i class="material-icons">description</i></button>
                        <button class="btn-icon btn-edit-custom" title="تعديل"><i class="material-icons">edit</i></button>
                        <button class="btn-icon btn-delete-custom" title="حذف"><i class="material-icons">delete</i></button>
                    </div>
                </div>
                <div class="card-body">
                    <div class="card-item"><strong>المتفق معه:</strong><span>${a.agreedWith}</span></div>
                    <div class="card-item"><strong>التاريخ:</strong><span>${new Date(a.date).toLocaleDateString('ar-EG')}</span></div>
                    ${calc}
                    <div class="card-item total-item"><strong>الإجمالي:</strong><span>${(a.total || 0).toLocaleString()} ج.م</span></div>
                </div>
                ${(a.details || a.notes) ? `
                    <div class="card-footer">
                        ${a.details ? `<div class="card-details-full"><strong>تفاصيل:</strong><p>${a.details}</p></div>` : ''}
                        ${a.notes ? `<div class="card-details-full"><strong>ملاحظات:</strong><p>${a.notes}</p></div>` : ''}
                    </div>
                ` : ''}
            </div>
        `;
    }

    function updateTotals() {
        const grand = allAgreementsData.reduce((s, a) => s + (a.total || 0), 0);
        let filtered = 0;
        document.querySelectorAll('.agreement-card').forEach(c => filtered += parseFloat((c as HTMLElement).dataset.total || '0'));
        
        const fEl = document.getElementById('filtered-agreements-total');
        const gEl = document.getElementById('grand-agreements-total');
        if(fEl) fEl.textContent = filtered.toLocaleString() + ' ج.م';
        if(gEl) gEl.textContent = grand.toLocaleString() + ' ج.م';
    }

    function openEditModal(id, data) {
        currentEditAgreementId = id;
        document.getElementById('modal-title').textContent = 'تعديل اتفاق';
        const f = document.getElementById('agreement-form') as any;
        f['agreement-title'].value = data.mainCategory;
        f['agreement-title'].dispatchEvent(new Event('change'));
        
        if(data.mainCategory === 'المقاول') f['contractor-subtype'].value = data.title;
        else if(data.mainCategory === 'اخري') f['other-agreement-title'].value = data.title;

        f['agreed-with'].value = data.agreedWith;
        f.date.value = data.date;
        f.area.value = data.area || '';
        f['price-per-meter'].value = data.pricePerMeter || '';
        f.quantity.value = data.quantity || '';
        f.price.value = data.price || '';
        f['agreement-total'].value = data.total;
        f['agreement-details'].value = data.details || '';
        f['agreement-notes'].value = data.notes || '';
        
        showModal(document.getElementById('agreement-modal'));
    }

    async function exportToPDF(card, data) {
        const canvas = await html2canvas(card);
        const img = canvas.toDataURL('image/png');
        const pdf = new jsPDF();
        pdf.addImage(img, 'PNG', 10, 10, 190, 0);
        pdf.save(`اتفاق_${data.title}.pdf`);
    }

    function exportToExcel(data) {
        const ws = XLSX.utils.json_to_sheet([data]);
        const wb = XLSX.utils.book_new();
        XLSX.utils.book_append_sheet(wb, ws, "Agreement");
        XLSX.writeFile(wb, `اتفاق_${data.title}.xlsx`);
    }

</script>

<style is:global>
:root {
    --primary-color: #3f51b5;
    --secondary-color: #6c757d;
    --danger-color: #d9534f;
    --success-color: #28a745;
    --light-gray: #f4f7f6;
    --dark-text: #333;
    --light-text: #555;
    --white: #fff;
    --border-color: #e0e0e0;
    --shadow: 0 4px 6px rgba(0,0,0,0.05);
    --card-shadow: 0 5px 15px rgba(0, 0, 0, 0.08);
    --card-hover-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
}
.agreements-admin-page { padding: 3rem 1.5rem; background-color: var(--light-gray); min-height: 100vh; direction: rtl; font-family: 'Cairo', sans-serif; }
.container { max-width: 1400px; margin: 0 auto; }
.auth-container { display: flex; align-items: center; justify-content: center; min-height: 100vh; }
.page-header { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 1rem; margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-color); }
.page-header h1 { font-size: 2.2rem; color: var(--dark-text); font-weight: 900; }
.page-subtitle { color: var(--light-text); margin-top: 0.25rem; }
.header-actions { display: flex; gap: 1rem; }
.btn { display: inline-block; padding: 0.7rem 1.3rem; color: var(--white); text-decoration: none; border-radius: 8px; font-size: 0.95rem; font-weight: 700; transition: all 0.2s ease-in-out; text-align: center; border: 1px solid transparent; cursor: pointer; }
.btn:hover { transform: translateY(-2px); }
.btn-primary { background-color: var(--primary-color); border-color: var(--primary-color); }
.btn-secondary { background-color: var(--secondary-color); border-color: var(--secondary-color); }
.btn-danger { background-color: var(--danger-color); border-color: var(--danger-color); }
.agreements-list-container { background-color: transparent; padding: 0; border-radius: 0; box-shadow: none; }

.list-controls { margin-bottom: 1rem; padding: 1rem; background-color: var(--white); border-radius: 8px; box-shadow: var(--shadow); display: flex; gap: 1rem; flex-wrap: wrap; justify-content: flex-start; }
.filter-group { display: flex; align-items: center; gap: 0.75rem; }
.filter-group label { font-weight: 700; color: var(--light-text); white-space: nowrap; }
.filter-group select { padding: 0.5rem 1rem; border: 1px solid var(--border-color); border-radius: 6px; font-size: 0.95rem; background-color: #fff; min-width: 200px; cursor: pointer; }

.totals-summary-container { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
.total-box { background-color: var(--white); padding: 1rem; border-radius: 8px; box-shadow: var(--shadow); border: 1px solid var(--border-color); }
.total-label { display: block; color: var(--secondary-color); font-size: 0.9rem; margin-bottom: 0.5rem; font-weight: 600; }
.total-value { display: block; font-size: 1.5rem; font-weight: 800; color: var(--dark-text); }
.grand-total-box { background-color: #e9f5ea; border-color: #a0d8a4; }
.grand-total-box .total-value { color: #1e8449; }

.agreements-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(400px, 1fr)); gap: 1.5rem; }
.agreement-card { background-color: var(--white); border-radius: 12px; box-shadow: var(--card-shadow); transition: transform 0.2s ease, box-shadow 0.2s ease; display: flex; flex-direction: column; }
