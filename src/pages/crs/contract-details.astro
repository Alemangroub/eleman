---
export const prerender = false;
import Layout from '../../layouts/Layout.astro';
import AdminLogin from '../../components/AdminLogin.astro';
import ConfirmModal from '../../components/ConfirmModal.astro';
import PartialPaymentModal from '../../components/PartialPaymentModal.astro';
---

<Layout title="تفاصيل العقد">
    <div id="auth-loading-message" class="auth-container">
        <p>جارٍ التحقق من صلاحيات الدخول...</p>
    </div>

    <div id="admin-login-container" class="auth-container" style="display: none;">
      <AdminLogin />
    </div>

    <main id="page-content" style="display: none;">
        <div class="details-container">
            <div class="details-header">
                <h1 id="customer-name-header">تفاصيل العقد</h1>
                <div class="header-buttons">
                    <button id="print-btn" class="btn btn-info">طباعة</button>
                    <button id="export-pdf-btn" class="btn btn-info">تصدير PDF</button>
                    <button id="export-excel-btn" class="btn btn-info">تصدير Excel</button>
                    <a id="edit-contract-btn" href="#" class="btn btn-warning">تعديل العقد</a>
                    <button id="delete-contract-btn" class="btn btn-danger">حذف العقد</button>
                    <a id="back-link" href="#" class="btn btn-secondary">&larr; العودة لقائمة العقود</a>
                </div>
            </div>

            <div id="loader">جاري تحميل البيانات...</div>
            <div id="error-display" class="message-card" style="display: none;">
                <h1>حدث خطأ</h1>
                <p id="error-message"></p>
            </div>

            <div id="contract-details-content" style="display: none;">
                <!-- Financial Summary -->
                <div class="summary-dashboard">
                    <div class="stat-card">
                        <h4>المبلغ الإجمالي للعقد</h4>
                        <p id="total-amount">0 ج.م.</p>
                    </div>
                    <div class="stat-card">
                        <h4 class="paid">إجمالي المدفوع</h4>
                        <p id="total-paid" class="paid">0 ج.م.</p>
                    </div>
                    <div class="stat-card">
                        <h4 class="remaining">المبلغ المتبقي</h4>
                        <p id="total-remaining" class="remaining">0 ج.م.</p>
                    </div>
                </div>

                <!-- Customer and Unit Info -->
                <div class="info-grid">
                    <div class="info-card">
                        <h3>بيانات العميل</h3>
                        <p><strong>الاسم:</strong> <span id="info-customer-name">-</span></p>
                        <p><strong>رقم الهاتف:</strong> <span id="info-customer-phone">-</span></p>
                    </div>
                    <div class="info-card">
                        <h3>بيانات الوحدة</h3>
                        <p><strong>نوع الوحدة:</strong> <span id="info-unit-type">-</span></p>
                        <p><strong>موقع/رقم الوحدة:</strong> <span id="info-unit-location">-</span></p>
                    </div>
                </div>

                <!-- Installments Section -->
                <div class="installments-section">
                    <h3>جدول الأقساط</h3>
                    <div class="table-responsive-wrapper">
                        <table id="installments-table" class="is-responsive">
                            <thead>
                                <tr>
                                    <th>م.</th>
                                    <th>مبلغ القسط</th>
                                    <th>تاريخ الاستحقاق</th>
                                    <th>الحالة</th>
                                    <th>تاريخ الدفع</th>
                                    <th>بيان القسط</th>
                                    <th>إجراءات</th>
                                </tr>
                            </thead>
                            <tbody>
                                <!-- Rows will be inserted here dynamically -->
                            </tbody>
                        </table>
                    </div>
                    <p id="no-installments-message" class="message-card" style="display: none;">لا توجد أقساط مسجلة لهذا العقد.</p>
                </div>
            </div>
        </div>
    </main>
    
    <ConfirmModal />
    <PartialPaymentModal />

</Layout>

<script>
  import { checkAuth, logout, getAuthHeaders } from '../../lib/auth.js';
  
  let currentProjectId = null;
  let currentCustomerName = null;
  let allInstallments = [];
  
  const formatCurrency = (num) => (num || 0).toLocaleString('ar-EG', { style: 'currency', currency: 'EGP' });
  const formatDate = (dateValue, format = 'long') => {
      if (!dateValue) return '-';
      const date = new Date(dateValue);
      if (isNaN(date.getTime())) return '-';
      if (format === 'yyyy-mm-dd') return date.toISOString().split('T')[0];
      return date.toLocaleDateString('ar-EG', { year: 'numeric', month: 'long', day: 'numeric' });
  };
  const unitTypeTranslations = { apartment: 'شقة', shop: 'محل', basement: 'بدروم', other: 'أخرى' };

  document.addEventListener('DOMContentLoaded', async () => {
      const authLoadingMessage = document.getElementById('auth-loading-message');
      const loginContainer = document.getElementById('admin-login-container');
      const pageContent = document.getElementById('page-content');

      const user = await checkAuth();
      if(authLoadingMessage) authLoadingMessage.style.display = 'none';

      if (user && user.role === 'admin') {
          if(pageContent) pageContent.style.display = 'block';
          if(loginContainer) loginContainer.style.display = 'none';
          initializeApp();
      } else {
          if(pageContent) pageContent.style.display = 'none';
          if(loginContainer) loginContainer.style.display = 'block';
      }
  });

  async function initializeApp() {
      const loader = document.getElementById('loader');
      const content = document.getElementById('contract-details-content');
      
      const urlParams = new URLSearchParams(window.location.search);
      currentProjectId = urlParams.get('projectId');
      currentCustomerName = urlParams.get('customerName');

      if (!currentProjectId || !currentCustomerName) {
          showError("بيانات المشروع أو العميل غير متوفرة.");
          return;
      }

      (document.getElementById('back-link') as HTMLAnchorElement).href = `/crs/project-installments?projectId=${currentProjectId}`;
      (document.getElementById('edit-contract-btn') as HTMLAnchorElement).href = `/crs/edit-contract?projectId=${currentProjectId}&customerName=${encodeURIComponent(currentCustomerName)}`;

      try {
          const response = await fetch(`/api/installments?projectId=${currentProjectId}&customerName=${encodeURIComponent(currentCustomerName)}`, { headers: getAuthHeaders() });
          const data = await response.json();

          if (!response.ok || data.length === 0) {
              showError("لم يتم العثور على أقساط.");
              return;
          }

          allInstallments = data;
          renderContractInfo(allInstallments[0]);
          renderInstallmentsTable(allInstallments);
          calculateSummary(allInstallments, allInstallments[0].totalAmount);
          
          if(loader) loader.style.display = 'none';
          if(content) content.style.display = 'block';

          setupInteractions();
      } catch (error) {
          showError("حدث خطأ أثناء تحميل البيانات.");
      }
  }

  function setupInteractions() {
      document.getElementById('print-btn')?.addEventListener('click', () => {
          const content = document.getElementById('contract-details-content');
          if (!content) return;
          
          // Add printable-area class to the content container
          const mainElement = document.getElementById('page-content');
          if (mainElement) mainElement.classList.add('printable-area');
          
          window.print();
          
          // Remove the class after printing
          if (mainElement) mainElement.classList.remove('printable-area');
      });
      document.getElementById('export-pdf-btn')?.addEventListener('click', exportPDF);
      document.getElementById('export-excel-btn')?.addEventListener('click', exportExcel);
      document.getElementById('delete-contract-btn')?.addEventListener('click', handleDeleteContract);

      const table = document.getElementById('installments-table');
      table?.addEventListener('click', (e) => {
          const target = e.target as HTMLElement;
          const btn = target.closest('button');
          if (!btn) return;

          const action = btn.classList.contains('btn-edit') ? 'edit' : 
                         btn.classList.contains('btn-save') ? 'save' : 
                         btn.classList.contains('btn-partial') ? 'partial' : 
                         btn.classList.contains('btn-delete-installment') ? 'delete' : null;

          if (action === 'edit') enterEditMode(btn.closest('tr'), btn);
          else if (action === 'save') saveInstallmentChanges(btn.closest('tr'), btn);
          else if (action === 'partial') handlePartialPayment(btn);
          else if (action === 'delete') handleDeleteInstallment(btn);
      });

      table?.addEventListener('change', (e) => {
          const target = e.target as HTMLSelectElement;
          if (target.classList.contains('status-select')) handleStatusChange(target);
      });
  }

  function showError(msg) {
      const loader = document.getElementById('loader');
      const errorDisplay = document.getElementById('error-display');
      const errorMessage = document.getElementById('error-message');
      if(loader) loader.style.display = 'none';
      if(errorMessage) errorMessage.textContent = msg;
      if(errorDisplay) errorDisplay.style.display = 'block';
  }

  function renderContractInfo(data) {
      document.getElementById('customer-name-header').textContent = `تفاصيل عقد: ${data.customerName}`;
      document.getElementById('info-customer-name').textContent = data.customerName || '-';
      document.getElementById('info-customer-phone').textContent = data.customerPhone || '-';
      document.getElementById('info-unit-type').textContent = unitTypeTranslations[data.unitType] || data.unitType || '-';
      document.getElementById('info-unit-location').textContent = data.unitLocation || '-';
  }

  function calculateSummary(installments, totalAmount) {
      const totalPaid = installments
          .filter(inst => inst.status === 'paid')
          .reduce((sum, inst) => sum + (inst.installmentAmount || 0), 0);
      const totalRemaining = totalAmount - totalPaid;
      document.getElementById('total-amount').textContent = formatCurrency(totalAmount);
      document.getElementById('total-paid').textContent = formatCurrency(totalPaid);
      document.getElementById('total-remaining').textContent = formatCurrency(totalRemaining);
  }

  function renderInstallmentsTable(installments) {
      const tableBody = document.querySelector('#installments-table tbody');
      if(!tableBody) return;
      tableBody.innerHTML = '';
      
      installments.forEach((inst, index) => {
          const isPaid = inst.status === 'paid';
          const row = document.createElement('tr');
          row.className = isPaid ? 'status-paid' : 'status-pending';
          
          // Group installments by due date to detect partial payments
          const sameDateInstallments = installments.filter(i => i.dueDate === inst.dueDate);
          const installmentNumbers = ['الأول', 'الثاني', 'الثالث', 'الرابع', 'الخامس', 'السادس', 'السابع', 'الثامن', 'التاسع', 'العاشر'];
          
          let installmentDescription = '';
          
          if (sameDateInstallments.length > 1) {
              // This is a partial payment situation
              const paidInstallments = sameDateInstallments.filter(i => i.status === 'paid');
              const pendingInstallments = sameDateInstallments.filter(i => i.status === 'pending');
              
              // Find the original installment order (by finding the highest amount)
              const originalAmount = Math.max(...sameDateInstallments.map(i => i.installmentAmount));
              const originalIndex = installments.findIndex(i => i.installmentAmount === originalAmount && i.dueDate === inst.dueDate);
              const originalNumber = installmentNumbers[originalIndex] || `رقم ${originalIndex + 1}`;
              
              if (isPaid && inst.installmentAmount < originalAmount) {
                  // This is a partial payment
                  installmentDescription = `دفعة من القسط ${originalNumber}`;
              } else if (!isPaid && inst.installmentAmount < originalAmount) {
                  // This is the remaining amount
                  installmentDescription = `الباقي من القسط ${originalNumber}`;
              } else {
                  // This is the original installment
                  installmentDescription = `القسط ${originalNumber}`;
              }
          } else {
              // Normal installment - check if it's a down payment (first installment and paid)
              const installmentNumber = installmentNumbers[index] || `رقم ${index + 1}`;
              
              if (index === 0 && isPaid) {
                  // First installment and already paid - likely a down payment
                  installmentDescription = `مدفوع مقدماً`;
              } else {
                  installmentDescription = `القسط ${installmentNumber}`;
              }
          }
          
          row.innerHTML = `
              <td data-label="م.">${index + 1}</td>
              <td data-label="مبلغ القسط" data-field="amount" data-original-value="${inst.installmentAmount}">${formatCurrency(inst.installmentAmount)}</td>
              <td data-label="تاريخ الاستحقاق" data-field="dueDate" data-original-value="${formatDate(inst.dueDate, 'yyyy-mm-dd')}">${formatDate(inst.dueDate)}</td>
              <td data-label="الحالة">
                  <select class="status-select" data-id="${inst.id}" data-current-status="${inst.status}">
                      <option value="pending" ${!isPaid ? 'selected' : ''}>مستحق</option>
                      <option value="paid" ${isPaid ? 'selected' : ''}>مدفوع</option>
                  </select>
              </td>
              <td data-label="تاريخ الدفع">${formatDate(inst.paidDate)}</td>
              <td data-label="بيان القسط">${installmentDescription}</td>
              <td data-label="إجراءات" class="actions-cell">
                  ${!isPaid ? `<button class="btn btn-partial btn-sm" data-id="${inst.id}">سداد جزئي</button>` : ''}
                  <button class="btn btn-edit btn-sm" data-id="${inst.id}">تعديل</button>
                  <button class="btn btn-delete-installment btn-sm btn-danger" data-id="${inst.id}">حذف</button>
              </td>
          `;
          tableBody.appendChild(row);
      });
  }

  async function handleStatusChange(select) {
      const id = select.dataset.id;
      const newStatus = select.value;
      if (await (window as any).showConfirmationModal(`تغيير حالة القسط؟`)) {
          try {
              const res = await fetch('/api/installments/update', {
                  method: 'PATCH',
                  headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                  body: JSON.stringify({ id, status: newStatus, paidDate: newStatus === 'paid' ? new Date() : null })
              });
              if (res.ok) initializeApp();
          } catch (e) { alert("خطأ في التحديث"); }
      } else {
          select.value = select.dataset.currentStatus;
      }
  }

  function enterEditMode(row, button) {
      row.classList.add('is-editing');
      button.textContent = 'حفظ';
      button.classList.replace('btn-edit', 'btn-save');

      const amountCell = row.querySelector('td[data-field="amount"]');
      const dateCell = row.querySelector('td[data-field="dueDate"]');

      amountCell.innerHTML = `<input type="number" class="edit-input" value="${amountCell.dataset.originalValue}">`;
      dateCell.innerHTML = `<input type="date" class="edit-input" value="${dateCell.dataset.originalValue}">`;
  }

  async function saveInstallmentChanges(row, button) {
      const id = button.dataset.id;
      const amount = parseFloat(row.querySelector('td[data-field="amount"] input').value);
      const date = row.querySelector('td[data-field="dueDate"] input').value;

      if (await (window as any).showConfirmationModal('حفظ التعديلات؟')) {
          try {
              const oldInst = allInstallments.find(i => i.id === id);
              const diff = amount - oldInst.installmentAmount;
              const newTotal = oldInst.totalAmount + diff;

              await fetch('/api/installments/update', {
                  method: 'PATCH',
                  headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                  body: JSON.stringify({ id, installmentAmount: amount, dueDate: new Date(date) })
              });

              await fetch('/api/installments/bulk-update', {
                  method: 'POST',
                  headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                  body: JSON.stringify({ projectId: currentProjectId, customerName: currentCustomerName, totalAmount: newTotal })
              });

              initializeApp();
          } catch (e) { alert("خطأ في الحفظ"); }
      }
  }

  async function handleDeleteInstallment(btn) {
      if (allInstallments.length <= 1) { alert("لا يمكن حذف القسط الأخير."); return; }
      if (await (window as any).showConfirmationModal('حذف هذا القسط؟')) {
          try {
              const id = btn.dataset.id;
              const inst = allInstallments.find(i => i.id === id);
              const newTotal = inst.totalAmount - inst.installmentAmount;

              await fetch('/api/installments/bulk-delete', {
                  method: 'POST',
                  headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                  body: JSON.stringify({ ids: [id], projectId: currentProjectId })
              });

              await fetch('/api/installments/bulk-update', {
                  method: 'POST',
                  headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                  body: JSON.stringify({ projectId: currentProjectId, customerName: currentCustomerName, totalAmount: newTotal })
              });

              initializeApp();
          } catch (e) { alert("خطأ في الحذف"); }
      }
  }

  async function handleDeleteContract() {
      if (await (window as any).showConfirmationModal('حذف العقد بالكامل؟')) {
          try {
              const res = await fetch('/api/installments/bulk-delete', {
                  method: 'POST',
                  headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                  body: JSON.stringify({ projectId: currentProjectId, customerName: currentCustomerName })
              });
              if (res.ok) window.location.href = `/crs/project-installments?projectId=${currentProjectId}`;
          } catch (e) { alert("خطأ في حذف العقد"); }
      }
  }

  async function handlePartialPayment(btn) {
      const id = btn.dataset.id;
      const inst = allInstallments.find(i => i.id === id);
      const paid = await (window as any).showPartialPaymentModal(id, inst.installmentAmount);

      if (paid && paid < inst.installmentAmount) {
          if (await (window as any).showConfirmationModal('تقسيم القسط؟')) {
              try {
                  await fetch('/api/installments/update', {
                      method: 'PATCH',
                      headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                      body: JSON.stringify({ id, installmentAmount: paid, status: 'paid', paidDate: new Date() })
                  });

                  await fetch('/api/installments/create', {
                      method: 'POST',
                      headers: getAuthHeaders({ 'Content-Type': 'application/json' }),
                      body: JSON.stringify({
                          projectId: inst.projectId, customerName: inst.customerName, customerPhone: inst.customerPhone,
                          unitType: inst.unitType, unitLocation: inst.unitLocation, totalAmount: inst.totalAmount,
                          installmentAmount: inst.installmentAmount - paid, dueDate: inst.dueDate, status: 'pending'
                      })
                  });
                  initializeApp();
              } catch (e) { alert("خطأ في الدفع الجزئي"); }
          }
      }
  }

  async function exportPDF() {
      const { jsPDF } = await import('jspdf');
      const { default: html2canvas } = await import('html2canvas');
      const content = document.getElementById('contract-details-content');
      const canvas = await html2canvas(content, { scale: 2 });
      const imgData = canvas.toDataURL('image/png');
      const pdf = new jsPDF('p', 'mm', 'a4');
      pdf.addImage(imgData, 'PNG', 0, 0, 210, (210 / canvas.width) * canvas.height);
      pdf.save(`${currentCustomerName}.pdf`);
  }

  async function exportExcel() {
      const XLSX = await import('xlsx');
      const table = document.getElementById('installments-table');
      const wb = XLSX.utils.table_to_book(table);
      XLSX.writeFile(wb, `${currentCustomerName}.xlsx`);
  }
</script>

<style is:global>
    :root {
        --primary-color: #2c3e50;
        --secondary-color: #7f8c8d;
        --success-color: #27ae60;
        --warning-color: #f39c12;
        --danger-color: #c0392b;
        --info-color: #3498db;
        --white-bg: #ffffff;
        --border-color: #e0e0e0;
        --shadow: 0 4px 12px rgba(0,0,0,0.06);
    }
    main#page-content { padding: 2rem 1rem; background-color: #f7f9fc; min-height: 100vh; direction: rtl; font-family: 'Cairo', sans-serif; }
    .details-container { max-width: 1200px; margin: 0 auto; }
    .details-header { display: flex; justify-content: space-between; align-items: center; border-bottom: 2px solid var(--border-color); padding-bottom: 1.5rem; margin-bottom: 2rem; flex-wrap: wrap; gap: 1rem; }
    h1 { font-size: 2rem; color: var(--primary-color); margin: 0; }
    .header-buttons { display: flex; gap: 0.5rem; flex-wrap: wrap; }
    .btn { padding: 0.6rem 1.2rem; border-radius: 8px; border: none; font-weight: 600; cursor: pointer; transition: 0.3s; color: white; display: inline-block; text-decoration: none; font-family: inherit; }
    .btn-info { background-color: var(--info-color); }
    .btn-warning { background-color: var(--warning-color); }
    .btn-danger { background-color: var(--danger-color); }
    .btn-secondary { background-color: var(--secondary-color); }
    .btn-sm { font-size: 0.85rem; padding: 0.4rem 0.8rem; }
    
    .summary-dashboard { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
    .stat-card { background: white; padding: 1.5rem; border-radius: 12px; box-shadow: var(--shadow); border-right: 5px solid var(--primary-color); text-align: center; }
    .stat-card h4 { margin: 0; color: #555; font-size: 1rem; }
    .stat-card p { font-size: 1.8rem; font-weight: 700; margin: 0.5rem 0 0; }
    .stat-card .paid { color: var(--success-color); }
    .stat-card .remaining { color: var(--danger-color); }

    .info-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2.5rem; }
    .info-card { background: white; padding: 1.5rem; border-radius: 12px; box-shadow: var(--shadow); }
    .info-card h3 { margin: 0 0 1rem 0; color: var(--primary-color); font-size: 1.2rem; }
    .info-card p { margin: 0.5rem 0; font-size: 1rem; }
    .info-card strong { color: #333; }
    
    .installments-section { background: white; padding: 2rem; border-radius: 12px; box-shadow: var(--shadow); }
    .installments-section h3 { color: var(--primary-color); margin-bottom: 1.5rem; font-size: 1.5rem; border-bottom: 2px solid var(--primary-color); padding-bottom: 0.5rem; }
    .table-responsive-wrapper { overflow-x: auto; }
    
    table { width: 100%; border-collapse: collapse; margin-bottom: 1rem; background: white; }
    thead th { 
        background: #f8f9fa; 
        color: #495057; 
        padding: 0.75rem; 
        text-align: right; 
        font-weight: 600; 
        font-size: 0.875rem;
        border-bottom: 1px solid #dee2e6;
        border-top: 1px solid #dee2e6;
    }
    tbody td { 
        padding: 0.75rem; 
        border-bottom: 1px solid #dee2e6; 
        vertical-align: middle;
        font-size: 0.875rem;
        color: #495057;
    }
    tbody tr:hover { background-color: rgba(0,0,0,.02); }
    
    .status-paid { background-color: #d4edda; }
    .status-paid td { color: #155724; }
    .status-pending { background-color: #fff3cd; }
    .status-pending td { color: #856404; }
    
    .status-select { 
        padding: 0.375rem 0.75rem; 
        border-radius: 0.25rem; 
        border: 1px solid #ced4da; 
        background: white; 
        font-weight: 400;
        cursor: pointer;
        transition: border-color .15s ease-in-out,box-shadow .15s ease-in-out;
        font-size: 0.875rem;
        color: #495057;
    }
    .status-select:focus { 
        outline: none; 
        border-color: #80bdff; 
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25); 
    }
    
    .edit-input { 
        width: 100%; 
        padding: 0.375rem 0.75rem; 
        border: 1px solid #ced4da; 
        border-radius: 0.25rem; 
        font-weight: 400;
        transition: border-color .15s ease-in-out,box-shadow .15s ease-in-out;
        font-size: 0.875rem;
        color: #495057;
    }
    .edit-input:focus { 
        outline: none; 
        border-color: #80bdff; 
        box-shadow: 0 0 0 0.2rem rgba(0,123,255,.25); 
    }
    
    .actions-cell { 
        display: flex; 
        gap: 0.25rem; 
        justify-content: flex-start;
        padding: 0.25rem 0;
        flex-wrap: wrap;
    }
    .actions-cell .btn { 
        color: #495057 !important; 
        background-color: #e9ecef !important; 
        border: 1px solid #ced4da !important; 
        font-size: 0.75rem;
        padding: 0.25rem 0.5rem;
        border-radius: 0.25rem;
