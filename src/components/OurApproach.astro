---
// Principle Icons
const qualityIcon = `<svg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' stroke='currentColor'> <path stroke-linecap='round' stroke-linejoin='round' d='M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.286zm0 13.036h.008v.008h-.008v-.008z' /> </svg>`;
const innovationIcon = `<svg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' stroke='currentColor'> <path stroke-linecap='round' stroke-linejoin='round' d='M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456zM16.898 20.528l-.259-1.035a3.375 3.375 0 00-2.455-2.456L13.15 16l1.035-.259a3.375 3.375 0 002.456-2.456l.259-1.035.259 1.035a3.375 3.375 0 002.456 2.456l1.035.259-1.035.259a3.375 3.375 0 00-2.456 2.456l-.259 1.035z' /> </svg>`;
const transparencyIcon = `<svg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 24 24' stroke-width='1.5' stroke='currentColor'> <path stroke-linecap='round' stroke-linejoin='round' d='M11.48 3.499a.562.562 0 011.04 0l2.125 5.111a.563.563 0 00.475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 00-.182.557l1.285 5.385a.562.562 0 01-.84.61l-4.725-2.885a.563.563 0 00-.586 0L6.982 20.54a.562.562 0 01-.84-.61l1.285-5.386a.562.562 0 00-.182-.557l-4.204-3.602a.563.563 0 01.321-.988l5.518-.442a.563.563 0 00.475-.345L11.48 3.5z' /> </svg>`;

const principles = [
  {
    icon: qualityIcon,
    title: "الجودة هي أساس عملنا",
    text: "الجودة في شركة الإيمان ليست مجرد شعار، بل هي حجر الزاوية في كل ما نقوم به. يمتد هذا الالتزام من مراحل التخطيط والتصميم الأولية، مرورًا باختيار أجود أنواع مواد البناء والتشطيب، وصولًا إلى أدق التفاصيل في التنفيذ والتسليم النهائي."
  },
  {
    icon: innovationIcon,
    title: "ابتكار يصنع المستقبل",
    text: "في عالم يتطور باستمرار، نرى في الابتكار محركًا أساسيًا للتميز. نسعى دائمًا لتطبيق أحدث التقنيات والتصاميم المعمارية التي تضيف قيمة حقيقية لمشاريعنا، و نقدم حلولاً ذكية للمساحات واستخدام مواد بناء صديقة للبيئة."
  },
  {
    icon: transparencyIcon,
    title: "شفافية تبني الثقة",
    text: "نؤمن بأن العلاقة مع عملائنا هي استثمار طويل الأمد، وأساس هذا الاستثمار هو الثقة. لذلك، نضع الشفافية في صميم جميع تعاملاتنا، ونحرص على تزويد عملائنا بكافة المعلومات والجداول الزمنية بوضوح كامل."
  }
];

// "How We Work" Icons
const planningIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /> </svg>`;
const designIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.83-5.83M11.42 15.17l-4.24-4.24a5.25 5.25 0 017.42 0L21 9.75M11.42 15.17L5.25 21" /> </svg>`;
const constructionIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 16.875h3.375m0 0h3.375m-3.375 0V13.5m0 3.375v3.375M6 10.5h2.25a2.25 2.25 0 002.25-2.25V6a2.25 2.25 0 00-2.25-2.25H6A2.25 2.25 0 003.75 6v2.25A2.25 2.25 0 006 10.5zm0 9.75h2.25A2.25 2.25 0 0010.5 18v-2.25a2.25 2.25 0 00-2.25-2.25H6a2.25 2.25 0 00-2.25 2.25V18A2.25 2.25 0 006 20.25z" /> </svg>`;
const deliveryIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z" /> </svg>`;


const workflow = [
    {
        icon: planningIcon,
        title: "1. الاستماع والتخطيط",
        text: "نبدأ بجلسة استشارية لفهم رؤيتك، متطلباتك، وميزانيتك. نضع معًا أساسًا متينًا وخطة عمل واضحة لمشروعك."
    },
    {
        icon: designIcon,
        title: "2. التصميم والإبداع",
        text: "يقوم فريقنا من المصممين والمهندسين بتحويل أفكارك إلى مخططات وتصاميم بصرية مبتكرة، مع التركيز على الجمال الوظيفي والاستغلال الأمثل للمساحات."
    },
    {
        icon: constructionIcon,
        title: "3. التنفيذ والبناء",
        text: "بإشراف هندسي دقيق، نبدأ عملية البناء باستخدام أجود المواد وأحدث الأساليب، مع إطلاعك المستمر على تقدم سير العمل."
    },
    {
        icon: deliveryIcon,
        title: "4. التسليم والدعم",
        text: "نسلمك مفتاح مشروعك جاهزًا كما تخيلته، مع ضماناتنا للجودة. ونبقى على تواصل لتقديم أي دعم قد تحتاجه بعد التسليم."
    }
];
---

<section class="our-principles">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">منهجيتنا في تقديم القيمة</h2>
      <p class="section-subtitle">نحن لا نبني عقارات فحسب، بل نبني ثقة وعلاقات تمتد للمستقبل. إليك كيف نضمن التميز في كل خدمة نقدمها.</p>
    </div>

    <div class="principles-timeline">
      {principles.map((principle, index) => (
        <div class="principle-step">
          <div class="principle-step-icon-wrapper">
            <div class="principle-step-icon" set:html={principle.icon} />
            {index < principles.length - 1 && <div class="principle-step-connector"></div>}
          </div>
          <div class="principle-step-content">
            <h3 class="principle-step-title">{principle.title}</h3>
            <p class="principle-step-text">{principle.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="how-we-work">
  <div class="container">
    <div class="section-header">
      <h2 class="section-title">رحلة مشروعك معنا</h2>
      <p class="section-subtitle">نؤمن بالشفافية والوضوح. إليك كيف نحول فكرتك إلى واقع ملموس عبر أربع مراحل أساسية.</p>
    </div>
    <div class="workflow-timeline">
      {workflow.map((step, index) => (
        <div class="workflow-step">
          <div class="step-icon-wrapper">
            <div class="step-icon" set:html={step.icon} />
            {index < workflow.length - 1 && <div class="step-connector"></div>}
          </div>
          <div class="step-content">
            <h3 class="step-title">{step.title}</h3>
            <p class="step-text">{step.text}</p>
          </div>
        </div>
      ))}
    </div>
     <div class="cta-container">
        <a href="/contact" class="cta-button">ابدأ رحلتك معنا</a>
    </div>
  </div>
</section>


<style>
.container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
}

.section-header {
    text-align: center;
    margin-bottom: 60px;
}

.section-title {
    font-family: 'Cairo', sans-serif;
    font-size: 2.8rem;
    font-weight: 700;
    color: #2c3e50;
    margin-bottom: 10px;
}

.section-subtitle {
    font-family: 'Almarai', sans-serif;
    font-size: 1.2rem;
    color: #5a6878;
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.7;
}

/* Our Principles Section */
.our-principles {
    padding: 80px 0 0 0;
    background-color: #fff;
    direction: rtl;
}

.principles-timeline {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 850px;
    margin: 60px auto 0 auto;
}

.principle-step {
    display: flex;
    align-items: flex-start;
    gap: 30px;
    position: relative;
}

.principle-step-icon-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
}

.principle-step-icon {
    width: 65px;
    height: 65px;
    background-color: #fff;
    color: #3498db;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 2px solid #e0e0e0;
    z-index: 2;
    transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
}

.principle-step:hover .principle-step-icon {
    background-color: #3498db;
    color: #fff;
    border-color: #3498db;
}

.principle-step-icon svg {
    width: 32px;
    height: 32px;
}

.principle-step-connector {
    width: 2px;
    height: calc(100% - 65px + 20px);
    background: #e0e0e0;
    position: absolute;
    top: 65px;
    z-index: 1;
}

.principle-step-content {
    padding-top: 15px;
    flex-grow: 1;
}

.principle-step-title {
    font-family: 'Cairo', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #34495e;
    margin-bottom: 8px;
}

.principle-step-text {
    font-family: 'Almarai', sans-serif;
    font-size: 1.05rem;
    color: #5a6878;
    line-height: 1.8;
}

/* How We Work Section */
.how-we-work {
    padding: 80px 0;
    background-color: #FDFCFB;
    direction: rtl;
    border-top: 1px solid #e0e0e0;
}

.workflow-timeline {
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-width: 850px;
    margin: 0 auto;
}

.workflow-step {
    display: flex;
    align-items: flex-start;
    gap: 30px;
    position: relative;
}

.step-icon-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    flex-shrink: 0;
}

.step-icon {
    width: 65px;
    height: 65px;
    background-color: #2c3e50;
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 4px solid #FDFCFB;
    box-shadow: 0 0 0 2px #2c3e50;
    z-index: 2;
}
.step-icon svg {
    width: 32px;
    height: 32px;
}

.step-connector {
    width: 2px;
    height: calc(100% - 65px + 20px);
    background: #dbe2e8;
    position: absolute;
    top: 65px;
    z-index: 1;
}

.step-content {
    padding-top: 15px;
    flex-grow: 1;
}

.step-title {
    font-family: 'Cairo', sans-serif;
    font-size: 1.5rem;
    font-weight: 700;
    color: #34495e;
    margin-bottom: 8px;
}

.step-text {
    font-family: 'Almarai', sans-serif;
    font-size: 1.05rem;
    color: #5a6878;
    line-height: 1.8;
}

.cta-container {
    text-align: center;
    margin-top: 60px;
}

.cta-button {
    font-family: 'Cairo', sans-serif;
    font-weight: 700;
    font-size: 1.1rem;
    color: #fff;
    background-color: #2c3e50;
    padding: 14px 45px;
    border-radius: 30px;
    text-decoration: none;
    transition: background-color 0.3s ease, transform 0.3s ease;
    display: inline-block;
    box-shadow: 0 5px 15px rgba(44, 62, 80, 0.2);
}

.cta-button:hover {
    background-color: #34495e;
    transform: translateY(-3px);
}

/* Responsive Styles */
@media (max-width: 768px) {
    .our-principles, .how-we-work {
        padding-top: 60px;
    }
    .section-title {
        font-size: 2.2rem;
    }
    .section-subtitle {
        font-size: 1.1rem;
    }

    .principle-step-icon, .step-icon {
        width: 55px;
        height: 55px;
    }
    .principle-step-icon svg, .step-icon svg {
      width: 28px; height: 28px;
    }
    .principle-step-connector, .step-connector { 
      height: calc(100% - 55px + 20px); top: 55px;
    }
    .principle-step, .workflow-step { gap: 20px; }
    .principle-step-content, .step-content { padding-top: 5px; }
    .principle-step-title, .step-title { font-size: 1.3rem; }
    .principle-step-text, .step-text { font-size: 1rem; }
}
</style>
