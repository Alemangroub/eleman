rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ---
    // Helper Functions
    // ---

    function isUserAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isUserRole(role) {
      return isUserAuthenticated() && getUserRole() == role;
    }

    function isProjectSupervisor(projectId) {
      let projectData = get(/databases/$(database)/documents/projects/$(projectId)).data;
      return isUserAuthenticated() && request.auth.uid in projectData.supervisorIds;
    }

    // ---
    // Collection Rules
    // ---

    // Users: REVISED FOR LOOKUPS
    match /users/{userId} {
      // Any authenticated user can GET any user document.
      // This is necessary for components to look up user display names.
      // LIST and WRITE operations remain restricted to admins.
      allow get: if isUserAuthenticated();
      allow list, write: if isUserRole('admin');
    }

    match /projects/{projectId} {
      allow read: if isUserRole('admin') || (isUserRole('supervisor') && request.auth.uid in resource.data.supervisorIds);
      allow write: if isUserRole('admin');

      match /items/{itemId} { allow read, write, delete: if isUserRole('admin'); }
      match /imports/{importId} { allow read, write, delete: if isUserRole('admin'); }
      match /agreements/{agreementId} { allow read, write, delete: if isUserRole('admin'); }
    }

    // Remains Collection (REVISED FOR QUERYING)
    match /remains/{remainId} {
        // GET: An admin can get any record. A supervisor can get records for their assigned projects.
        allow get: if isUserRole('admin') || (isUserRole('supervisor') && isProjectSupervisor(resource.data.projectId));

        // LIST: Admins can list everything. Supervisors can ONLY list records if they filter by a projectId they are assigned to.
        allow list: if isUserRole('admin') || 
                    (isUserRole('supervisor') && isProjectSupervisor(request.query.filters.projectId));

        // CREATE: Admins or supervisors can add new records to projects they are assigned to.
        allow create: if isUserRole('admin') || 
                      (isUserRole('supervisor') && isProjectSupervisor(request.resource.data.projectId));

        // UPDATE / DELETE: Only admins can modify or delete historical records for data integrity.
        allow update, delete: if isUserRole('admin');
    }

    // Daily Expenses & Reports: Supervisors can create, Admins can manage.
    match /daily_expenses/{expenseId} {
      allow create: if isUserRole('supervisor');
      allow read, update, delete: if isUserRole('admin');
    }

    match /daily_reports/{reportId} {
      allow create: if isUserRole('supervisor');
      allow read, update, delete: if isUserRole('admin');
    }

    // Contracts & Installments: Only Admins have access.
    match /contracts/{contractId} { allow read, write, delete: if isUserRole('admin'); }
    match /installments/{installmentId} { allow read, write, delete: if isUserRole('admin'); }
  }
}
